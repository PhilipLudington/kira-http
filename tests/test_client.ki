/// Tests for kira-http client module
///
/// Tests request builder pattern and URL validation concepts.
/// Self-contained for Kira v0.1.0 (no module system support).

// ============================================================================
// Type Definitions
// ============================================================================

type Method =
    | GET
    | POST
    | PUT
    | DELETE
    | PATCH
    | HEAD
    | OPTIONS

type Header = {
    name: string,
    value: string
}

type Headers = List[Header]

type Status =
    | OK
    | Created
    | MovedPermanently
    | Found
    | TemporaryRedirect
    | PermanentRedirect
    | NotFound
    | Custom(i32)

type HttpError =
    | InvalidUrl(string)
    | ConnectionFailed(string)
    | Timeout
    | TooManyRedirects

type RequestBuilder = {
    method: Method,
    url: string,
    headers: Headers,
    body: Option[string],
    timeout: Option[i32],
    max_redirects: Option[i32]
}

type Request = {
    method: Method,
    url: string,
    headers: Headers,
    body: Option[string],
    timeout: Option[i32]
}

// ============================================================================
// Helper Functions
// ============================================================================

let new_request: fn(Method, string) -> RequestBuilder =
    fn(method: Method, url: string) -> RequestBuilder {
        return RequestBuilder {
            method: method,
            url: url,
            headers: Nil,
            body: None,
            timeout: None,
            max_redirects: None
        }
    }

let with_header: fn(RequestBuilder, string, string) -> RequestBuilder =
    fn(builder: RequestBuilder, name: string, value: string) -> RequestBuilder {
        let new_header: Header = Header { name: name, value: value }
        return RequestBuilder {
            method: builder.method,
            url: builder.url,
            headers: Cons(new_header, builder.headers),
            body: builder.body,
            timeout: builder.timeout,
            max_redirects: builder.max_redirects
        }
    }

let with_body: fn(RequestBuilder, string) -> RequestBuilder =
    fn(builder: RequestBuilder, body: string) -> RequestBuilder {
        return RequestBuilder {
            method: builder.method,
            url: builder.url,
            headers: builder.headers,
            body: Some(body),
            timeout: builder.timeout,
            max_redirects: builder.max_redirects
        }
    }

let with_timeout: fn(RequestBuilder, i32) -> RequestBuilder =
    fn(builder: RequestBuilder, ms: i32) -> RequestBuilder {
        return RequestBuilder {
            method: builder.method,
            url: builder.url,
            headers: builder.headers,
            body: builder.body,
            timeout: Some(ms),
            max_redirects: builder.max_redirects
        }
    }

let with_max_redirects: fn(RequestBuilder, i32) -> RequestBuilder =
    fn(builder: RequestBuilder, n: i32) -> RequestBuilder {
        return RequestBuilder {
            method: builder.method,
            url: builder.url,
            headers: builder.headers,
            body: builder.body,
            timeout: builder.timeout,
            max_redirects: Some(n)
        }
    }

let build: fn(RequestBuilder) -> Request =
    fn(builder: RequestBuilder) -> Request {
        return Request {
            method: builder.method,
            url: builder.url,
            headers: builder.headers,
            body: builder.body,
            timeout: builder.timeout
        }
    }

let methods_equal: fn(Method, Method) -> bool = fn(a: Method, b: Method) -> bool {
    var result: bool
    match a {
        GET => { match b { GET => { result = true } _ => { result = false } } }
        POST => { match b { POST => { result = true } _ => { result = false } } }
        PUT => { match b { PUT => { result = true } _ => { result = false } } }
        DELETE => { match b { DELETE => { result = true } _ => { result = false } } }
        PATCH => { match b { PATCH => { result = true } _ => { result = false } } }
        HEAD => { match b { HEAD => { result = true } _ => { result = false } } }
        OPTIONS => { match b { OPTIONS => { result = true } _ => { result = false } } }
    }
    return result
}

let has_header: fn(Headers, string) -> bool =
    fn(headers: Headers, name: string) -> bool {
        var result: bool
        match headers {
            Nil => { result = false }
            Cons(h, rest) => {
                if h.name == name {
                    result = true
                } else {
                    result = has_header(rest, name)
                }
            }
        }
        return result
    }

let is_valid_url: fn(string) -> bool = fn(url: string) -> bool {
    if std.string.length(url) == 0 {
        return false
    }
    let has_http: bool = std.string.starts_with(url, "http://")
    let has_https: bool = std.string.starts_with(url, "https://")
    return has_http or has_https
}

// ============================================================================
// Tests: Request builder creation
// ============================================================================

test "new_request sets method" {
    let builder: RequestBuilder = new_request(GET, "https://example.com")
    assert(methods_equal(builder.method, GET))
}

test "new_request sets url" {
    let builder: RequestBuilder = new_request(GET, "https://example.com/api")
    assert(builder.url == "https://example.com/api")
}

test "new_request has empty headers" {
    let builder: RequestBuilder = new_request(GET, "https://example.com")
    var is_empty: bool
    match builder.headers {
        Nil => { is_empty = true }
        Cons(_, _) => { is_empty = false }
    }
    assert(is_empty)
}

test "new_request has no body" {
    let builder: RequestBuilder = new_request(GET, "https://example.com")
    var has_no_body: bool
    match builder.body {
        None => { has_no_body = true }
        Some(_) => { has_no_body = false }
    }
    assert(has_no_body)
}

test "new_request has no timeout" {
    let builder: RequestBuilder = new_request(GET, "https://example.com")
    var has_no_timeout: bool
    match builder.timeout {
        None => { has_no_timeout = true }
        Some(_) => { has_no_timeout = false }
    }
    assert(has_no_timeout)
}

// ============================================================================
// Tests: All HTTP methods
// ============================================================================

test "POST method" {
    let builder: RequestBuilder = new_request(POST, "https://example.com")
    assert(methods_equal(builder.method, POST))
}

test "PUT method" {
    let builder: RequestBuilder = new_request(PUT, "https://example.com")
    assert(methods_equal(builder.method, PUT))
}

test "DELETE method" {
    let builder: RequestBuilder = new_request(DELETE, "https://example.com")
    assert(methods_equal(builder.method, DELETE))
}

test "PATCH method" {
    let builder: RequestBuilder = new_request(PATCH, "https://example.com")
    assert(methods_equal(builder.method, PATCH))
}

test "HEAD method" {
    let builder: RequestBuilder = new_request(HEAD, "https://example.com")
    assert(methods_equal(builder.method, HEAD))
}

test "OPTIONS method" {
    let builder: RequestBuilder = new_request(OPTIONS, "https://example.com")
    assert(methods_equal(builder.method, OPTIONS))
}

// ============================================================================
// Tests: with_header
// ============================================================================

test "with_header adds header" {
    let b1: RequestBuilder = new_request(GET, "https://example.com")
    let builder: RequestBuilder = with_header(b1, "Authorization", "Bearer token")
    assert(has_header(builder.headers, "Authorization"))
}

test "with_header chains multiple" {
    let b1: RequestBuilder = new_request(GET, "https://example.com")
    let b2: RequestBuilder = with_header(b1, "Authorization", "Bearer token")
    let builder: RequestBuilder = with_header(b2, "Accept", "application/json")
    assert(has_header(builder.headers, "Authorization"))
    assert(has_header(builder.headers, "Accept"))
}

// ============================================================================
// Tests: with_body
// ============================================================================

test "with_body sets body" {
    let b1: RequestBuilder = new_request(POST, "https://example.com")
    let builder: RequestBuilder = with_body(b1, "test body")
    var has_body: bool
    match builder.body {
        Some(b) => { has_body = b == "test body" }
        None => { has_body = false }
    }
    assert(has_body)
}

test "with_body replaces body" {
    let b1: RequestBuilder = new_request(POST, "https://example.com")
    let b2: RequestBuilder = with_body(b1, "first")
    let builder: RequestBuilder = with_body(b2, "second")
    var has_body: bool
    match builder.body {
        Some(b) => { has_body = b == "second" }
        None => { has_body = false }
    }
    assert(has_body)
}

// ============================================================================
// Tests: with_timeout
// ============================================================================

test "with_timeout sets timeout" {
    let b1: RequestBuilder = new_request(GET, "https://example.com")
    let builder: RequestBuilder = with_timeout(b1, 5000)
    var has_timeout: bool
    match builder.timeout {
        Some(t) => { has_timeout = t == 5000 }
        None => { has_timeout = false }
    }
    assert(has_timeout)
}

test "with_timeout replaces timeout" {
    let b1: RequestBuilder = new_request(GET, "https://example.com")
    let b2: RequestBuilder = with_timeout(b1, 1000)
    let builder: RequestBuilder = with_timeout(b2, 5000)
    var has_timeout: bool
    match builder.timeout {
        Some(t) => { has_timeout = t == 5000 }
        None => { has_timeout = false }
    }
    assert(has_timeout)
}

// ============================================================================
// Tests: build
// ============================================================================

test "build creates request" {
    let b1: RequestBuilder = new_request(GET, "https://example.com")
    let request: Request = build(b1)
    assert(methods_equal(request.method, GET))
    assert(request.url == "https://example.com")
}

test "build preserves headers" {
    let b1: RequestBuilder = new_request(GET, "https://example.com")
    let builder: RequestBuilder = with_header(b1, "Accept", "application/json")
    let request: Request = build(builder)
    assert(has_header(request.headers, "Accept"))
}

test "build preserves body" {
    let b1: RequestBuilder = new_request(POST, "https://example.com")
    let builder: RequestBuilder = with_body(b1, "body content")
    let request: Request = build(builder)
    var has_body: bool
    match request.body {
        Some(b) => { has_body = b == "body content" }
        None => { has_body = false }
    }
    assert(has_body)
}

test "build preserves timeout" {
    let b1: RequestBuilder = new_request(GET, "https://example.com")
    let builder: RequestBuilder = with_timeout(b1, 5000)
    let request: Request = build(builder)
    var has_timeout: bool
    match request.timeout {
        Some(t) => { has_timeout = t == 5000 }
        None => { has_timeout = false }
    }
    assert(has_timeout)
}

test "build has no timeout by default" {
    let b1: RequestBuilder = new_request(GET, "https://example.com")
    let request: Request = build(b1)
    var has_no_timeout: bool
    match request.timeout {
        None => { has_no_timeout = true }
        Some(_) => { has_no_timeout = false }
    }
    assert(has_no_timeout)
}

// ============================================================================
// Tests: URL validation
// ============================================================================

test "empty URL is invalid" {
    assert(is_valid_url("") == false)
}

test "http URL is valid" {
    assert(is_valid_url("http://example.com") == true)
}

test "https URL is valid" {
    assert(is_valid_url("https://example.com") == true)
}

test "ftp URL is invalid" {
    assert(is_valid_url("ftp://example.com") == false)
}

test "plain string is invalid URL" {
    assert(is_valid_url("not-a-url") == false)
}

// ============================================================================
// Tests: Chained builder
// ============================================================================

test "chained builder preserves all" {
    let b1: RequestBuilder = new_request(POST, "https://api.example.com/users")
    let b2: RequestBuilder = with_header(b1, "Content-Type", "application/json")
    let b3: RequestBuilder = with_header(b2, "Authorization", "Bearer token")
    let b4: RequestBuilder = with_body(b3, "{\"name\": \"Alice\"}")
    let builder: RequestBuilder = with_timeout(b4, 10000)

    assert(methods_equal(builder.method, POST))
    assert(builder.url == "https://api.example.com/users")
    assert(has_header(builder.headers, "Content-Type"))
    assert(has_header(builder.headers, "Authorization"))

    var has_body: bool
    match builder.body {
        Some(b) => { has_body = b == "{\"name\": \"Alice\"}" }
        None => { has_body = false }
    }
    assert(has_body)

    var has_timeout: bool
    match builder.timeout {
        Some(t) => { has_timeout = t == 10000 }
        None => { has_timeout = false }
    }
    assert(has_timeout)
}

// ============================================================================
// Redirect helper functions
// ============================================================================

let status_code: fn(Status) -> i32 = fn(status: Status) -> i32 {
    var code: i32
    match status {
        OK => { code = 200 }
        Created => { code = 201 }
        MovedPermanently => { code = 301 }
        Found => { code = 302 }
        TemporaryRedirect => { code = 307 }
        PermanentRedirect => { code = 308 }
        NotFound => { code = 404 }
        Custom(n) => { code = n }
    }
    return code
}

let is_followable_redirect: fn(Status) -> bool = fn(status: Status) -> bool {
    let code: i32 = status_code(status)
    return code == 301 or code == 302 or code == 307 or code == 308
}

let should_change_method: fn(Status) -> bool = fn(status: Status) -> bool {
    let code: i32 = status_code(status)
    return code == 301 or code == 302
}

// ============================================================================
// Tests: with_max_redirects
// ============================================================================

test "with_max_redirects sets max_redirects" {
    let b1: RequestBuilder = new_request(GET, "https://example.com")
    let builder: RequestBuilder = with_max_redirects(b1, 5)
    var has_max: bool
    match builder.max_redirects {
        Some(n) => { has_max = n == 5 }
        None => { has_max = false }
    }
    assert(has_max)
}

test "with_max_redirects replaces max_redirects" {
    let b1: RequestBuilder = new_request(GET, "https://example.com")
    let b2: RequestBuilder = with_max_redirects(b1, 5)
    let builder: RequestBuilder = with_max_redirects(b2, 3)
    var has_max: bool
    match builder.max_redirects {
        Some(n) => { has_max = n == 3 }
        None => { has_max = false }
    }
    assert(has_max)
}

test "new_request has no max_redirects" {
    let builder: RequestBuilder = new_request(GET, "https://example.com")
    var has_no_max: bool
    match builder.max_redirects {
        None => { has_no_max = true }
        Some(_) => { has_no_max = false }
    }
    assert(has_no_max)
}

test "with_max_redirects zero disables redirects" {
    let b1: RequestBuilder = new_request(GET, "https://example.com")
    let builder: RequestBuilder = with_max_redirects(b1, 0)
    var has_max: bool
    match builder.max_redirects {
        Some(n) => { has_max = n == 0 }
        None => { has_max = false }
    }
    assert(has_max)
}

test "with_max_redirects preserves other fields" {
    let b1: RequestBuilder = new_request(POST, "https://example.com")
    let b2: RequestBuilder = with_header(b1, "Accept", "application/json")
    let b3: RequestBuilder = with_body(b2, "test body")
    let builder: RequestBuilder = with_max_redirects(b3, 5)
    assert(methods_equal(builder.method, POST))
    assert(builder.url == "https://example.com")
    assert(has_header(builder.headers, "Accept"))
    var has_body: bool
    match builder.body {
        Some(b) => { has_body = b == "test body" }
        None => { has_body = false }
    }
    assert(has_body)
}

// ============================================================================
// Tests: Redirect status detection
// ============================================================================

test "is_followable_redirect true for 301" {
    assert(is_followable_redirect(MovedPermanently) == true)
}

test "is_followable_redirect true for 302" {
    assert(is_followable_redirect(Found) == true)
}

test "is_followable_redirect true for 307" {
    assert(is_followable_redirect(TemporaryRedirect) == true)
}

test "is_followable_redirect true for 308" {
    assert(is_followable_redirect(PermanentRedirect) == true)
}

test "is_followable_redirect false for 200" {
    assert(is_followable_redirect(OK) == false)
}

test "is_followable_redirect false for 404" {
    assert(is_followable_redirect(NotFound) == false)
}

// ============================================================================
// Tests: Method change on redirect
// ============================================================================

test "should_change_method true for 301" {
    assert(should_change_method(MovedPermanently) == true)
}

test "should_change_method true for 302" {
    assert(should_change_method(Found) == true)
}

test "should_change_method false for 307" {
    assert(should_change_method(TemporaryRedirect) == false)
}

test "should_change_method false for 308" {
    assert(should_change_method(PermanentRedirect) == false)
}

// ============================================================================
// Redirect URL resolution
// ============================================================================

let resolve_redirect_url: fn(string, string) -> string =
    fn(original_url: string, location: string) -> string {
        let has_http: bool = std.string.starts_with(location, "http://")
        let has_https: bool = std.string.starts_with(location, "https://")
        if has_http or has_https {
            return location
        }

        let scheme_end: Option[i64] = std.string.index_of(original_url, "://")
        match scheme_end {
            Some(idx) => {
                let after_scheme: string = std.string.substring(original_url, idx + 3, std.string.length(original_url)) ?? ""
                let host_end: Option[i64] = std.string.index_of(after_scheme, "/")
                var origin: string
                match host_end {
                    Some(hidx) => {
                        let scheme_and_sep: string = std.string.substring(original_url, 0, idx + 3) ?? ""
                        let host: string = std.string.substring(after_scheme, 0, hidx) ?? ""
                        origin = scheme_and_sep + host
                    }
                    None => {
                        origin = original_url
                    }
                }

                if std.string.starts_with(location, "/") {
                    return origin + location
                } else {
                    return origin + "/" + location
                }
            }
            None => {
                return location
            }
        }
    }

// ============================================================================
// Tests: Redirect URL resolution
// ============================================================================

test "resolve_redirect_url returns absolute URL as-is" {
    let result: string = resolve_redirect_url(
        "https://example.com/old",
        "https://other.com/new"
    )
    assert(result == "https://other.com/new")
}

test "resolve_redirect_url resolves relative path against origin" {
    let result: string = resolve_redirect_url(
        "https://example.com/old/path",
        "/new/path"
    )
    assert(result == "https://example.com/new/path")
}

test "resolve_redirect_url resolves root path" {
    let result: string = resolve_redirect_url(
        "https://example.com/some/deep/path",
        "/"
    )
    assert(result == "https://example.com/")
}

test "resolve_redirect_url handles http scheme" {
    let result: string = resolve_redirect_url(
        "http://example.com/old",
        "/new"
    )
    assert(result == "http://example.com/new")
}

test "resolve_redirect_url handles port in origin" {
    let result: string = resolve_redirect_url(
        "https://example.com:8080/old",
        "/new"
    )
    assert(result == "https://example.com:8080/new")
}

test "resolve_redirect_url handles origin without path" {
    let result: string = resolve_redirect_url(
        "https://example.com",
        "/new"
    )
    assert(result == "https://example.com/new")
}

test "resolve_redirect_url handles relative path without leading slash" {
    let result: string = resolve_redirect_url(
        "https://example.com/old",
        "new"
    )
    assert(result == "https://example.com/new")
}

test "resolve_redirect_url preserves http absolute URL" {
    let result: string = resolve_redirect_url(
        "https://example.com/old",
        "http://other.com/path"
    )
    assert(result == "http://other.com/path")
}
