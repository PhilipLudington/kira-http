/// Tests for kira-http server module
///
/// Tests request type structure and response serialization concepts.
/// Self-contained for Kira v0.1.0 (no module system support).

// ============================================================================
// Type Definitions
// ============================================================================

type Method =
    | GET
    | POST
    | PUT
    | DELETE
    | PATCH
    | HEAD
    | OPTIONS

type Status =
    | OK
    | Created
    | NoContent
    | BadRequest
    | NotFound
    | InternalError

type Header = {
    name: string,
    value: string
}

type Headers = List[Header]

type QueryParam = {
    key: string,
    value: string
}

type Request = {
    method: Method,
    url: string,
    path: string,
    headers: Headers,
    body: Option[string],
    query: List[QueryParam]
}

type Response = {
    status: Status,
    headers: Headers,
    body: string
}

type Handler = fn(Request) -> Response

// ============================================================================
// Helper Functions
// ============================================================================

let ok: fn(string) -> Response = fn(body: string) -> Response {
    return Response {
        status: OK,
        headers: Nil,
        body: body
    }
}

let make_request: fn(Method, string) -> Request =
    fn(method: Method, path: string) -> Request {
        return Request {
            method: method,
            url: "http://localhost" + path,
            path: path,
            headers: Nil,
            body: None,
            query: Nil
        }
    }

let methods_equal: fn(Method, Method) -> bool = fn(a: Method, b: Method) -> bool {
    var result: bool
    match a {
        GET => { match b { GET => { result = true } _ => { result = false } } }
        POST => { match b { POST => { result = true } _ => { result = false } } }
        PUT => { match b { PUT => { result = true } _ => { result = false } } }
        DELETE => { match b { DELETE => { result = true } _ => { result = false } } }
        PATCH => { match b { PATCH => { result = true } _ => { result = false } } }
        HEAD => { match b { HEAD => { result = true } _ => { result = false } } }
        OPTIONS => { match b { OPTIONS => { result = true } _ => { result = false } } }
    }
    return result
}

let status_code: fn(Status) -> i32 = fn(status: Status) -> i32 {
    var code: i32
    match status {
        OK => { code = 200 }
        Created => { code = 201 }
        NoContent => { code = 204 }
        BadRequest => { code = 400 }
        NotFound => { code = 404 }
        InternalError => { code = 500 }
    }
    return code
}

let status_text: fn(Status) -> string = fn(status: Status) -> string {
    var text: string
    match status {
        OK => { text = "OK" }
        Created => { text = "Created" }
        NoContent => { text = "No Content" }
        BadRequest => { text = "Bad Request" }
        NotFound => { text = "Not Found" }
        InternalError => { text = "Internal Server Error" }
    }
    return text
}

// ============================================================================
// Tests: Request structure
// ============================================================================

test "request has method" {
    let req: Request = make_request(GET, "/api")
    assert(methods_equal(req.method, GET))
}

test "request has path" {
    let req: Request = make_request(GET, "/users/123")
    assert(req.path == "/users/123")
}

test "request has url" {
    let req: Request = make_request(GET, "/api")
    assert(req.url == "http://localhost/api")
}

test "request has empty headers by default" {
    let req: Request = make_request(GET, "/")
    var is_empty: bool
    match req.headers {
        Nil => { is_empty = true }
        Cons(_, _) => { is_empty = false }
    }
    assert(is_empty)
}

test "request has no body by default" {
    let req: Request = make_request(GET, "/")
    var has_no_body: bool
    match req.body {
        None => { has_no_body = true }
        Some(_) => { has_no_body = false }
    }
    assert(has_no_body)
}

test "request has empty query by default" {
    let req: Request = make_request(GET, "/")
    var is_empty: bool
    match req.query {
        Nil => { is_empty = true }
        Cons(_, _) => { is_empty = false }
    }
    assert(is_empty)
}

// ============================================================================
// Tests: Response structure
// ============================================================================

test "response has status" {
    let resp: Response = ok("test")
    var is_ok: bool
    match resp.status {
        OK => { is_ok = true }
        _ => { is_ok = false }
    }
    assert(is_ok)
}

test "response has body" {
    let resp: Response = ok("Hello, World!")
    assert(resp.body == "Hello, World!")
}

test "response has empty headers" {
    let resp: Response = ok("test")
    var is_empty: bool
    match resp.headers {
        Nil => { is_empty = true }
        Cons(_, _) => { is_empty = false }
    }
    assert(is_empty)
}

// ============================================================================
// Tests: Status codes
// ============================================================================

test "OK status code is 200" {
    assert(status_code(OK) == 200)
}

test "Created status code is 201" {
    assert(status_code(Created) == 201)
}

test "NoContent status code is 204" {
    assert(status_code(NoContent) == 204)
}

test "BadRequest status code is 400" {
    assert(status_code(BadRequest) == 400)
}

test "NotFound status code is 404" {
    assert(status_code(NotFound) == 404)
}

test "InternalError status code is 500" {
    assert(status_code(InternalError) == 500)
}

// ============================================================================
// Tests: Status text
// ============================================================================

test "OK status text" {
    assert(status_text(OK) == "OK")
}

test "Created status text" {
    assert(status_text(Created) == "Created")
}

test "NotFound status text" {
    assert(status_text(NotFound) == "Not Found")
}

// ============================================================================
// Tests: Handler type
// ============================================================================

test "handler is function from request to response" {
    let handler: Handler = fn(req: Request) -> Response {
        return ok("handled: " + req.path)
    }
    let req: Request = make_request(GET, "/test")
    let resp: Response = handler(req)
    assert(resp.body == "handled: /test")
}

test "handler can access request method" {
    let handler: Handler = fn(req: Request) -> Response {
        var method_name: string
        match req.method {
            GET => { method_name = "GET" }
            POST => { method_name = "POST" }
            _ => { method_name = "OTHER" }
        }
        return ok(method_name)
    }
    let req: Request = make_request(POST, "/")
    let resp: Response = handler(req)
    assert(resp.body == "POST")
}

test "handler can return different status" {
    let handler: Handler = fn(req: Request) -> Response {
        return Response {
            status: NotFound,
            headers: Nil,
            body: "Not Found"
        }
    }
    let req: Request = make_request(GET, "/missing")
    let resp: Response = handler(req)
    var is_not_found: bool
    match resp.status {
        NotFound => { is_not_found = true }
        _ => { is_not_found = false }
    }
    assert(is_not_found)
}
