test "no_content sets NoContent status" {
    let response: Response = no_content()
    var matches: bool
    match response.status {
        NoContent => { matches = true }
        _ => { matches = false }
    }
    assert(matches)
}

test "no_content has empty body" {
    let response: Response = no_content()
    assert(response.body == "")
}

test "no_content has no headers" {
    let response: Response = no_content()
    var is_empty: bool
    match response.headers {
        Nil => { is_empty = true }
        Cons(_, _) => { is_empty = false }
    }
    assert(is_empty)
}

