/// Tests for kira-http core types
///
/// Tests status code conversion, status category checks, and header manipulation.
/// Self-contained for Kira v0.1.0 (no module system support).

// ============================================================================
// Type Definitions (from src/types.ki)
// ============================================================================

type Status =
    | OK
    | Created
    | Accepted
    | NoContent
    | MovedPermanently
    | Found
    | TemporaryRedirect
    | PermanentRedirect
    | NotModified
    | BadRequest
    | Unauthorized
    | Forbidden
    | NotFound
    | MethodNotAllowed
    | Conflict
    | InternalError
    | NotImplemented
    | BadGateway
    | ServiceUnavailable
    | Custom(i32)

type Header = {
    name: string,
    value: string
}

type Headers = List[Header]

// ============================================================================
// Functions (from src/status.ki)
// ============================================================================

let status_code: fn(Status) -> i32 = fn(status: Status) -> i32 {
    var code: i32
    match status {
        OK => { code = 200 }
        Created => { code = 201 }
        Accepted => { code = 202 }
        NoContent => { code = 204 }
        MovedPermanently => { code = 301 }
        Found => { code = 302 }
        TemporaryRedirect => { code = 307 }
        PermanentRedirect => { code = 308 }
        NotModified => { code = 304 }
        BadRequest => { code = 400 }
        Unauthorized => { code = 401 }
        Forbidden => { code = 403 }
        NotFound => { code = 404 }
        MethodNotAllowed => { code = 405 }
        Conflict => { code = 409 }
        InternalError => { code = 500 }
        NotImplemented => { code = 501 }
        BadGateway => { code = 502 }
        ServiceUnavailable => { code = 503 }
        Custom(n) => { code = n }
    }
    return code
}

let status_from_code: fn(i32) -> Status = fn(code: i32) -> Status {
    var status: Status
    match code {
        200 => { status = OK }
        201 => { status = Created }
        202 => { status = Accepted }
        204 => { status = NoContent }
        301 => { status = MovedPermanently }
        302 => { status = Found }
        307 => { status = TemporaryRedirect }
        308 => { status = PermanentRedirect }
        304 => { status = NotModified }
        400 => { status = BadRequest }
        401 => { status = Unauthorized }
        403 => { status = Forbidden }
        404 => { status = NotFound }
        405 => { status = MethodNotAllowed }
        409 => { status = Conflict }
        500 => { status = InternalError }
        501 => { status = NotImplemented }
        502 => { status = BadGateway }
        503 => { status = ServiceUnavailable }
        _ => { status = Custom(code) }
    }
    return status
}

let is_success: fn(Status) -> bool = fn(status: Status) -> bool {
    let code: i32 = status_code(status)
    return code >= 200 and code < 300
}

let is_redirect: fn(Status) -> bool = fn(status: Status) -> bool {
    let code: i32 = status_code(status)
    return code >= 300 and code < 400
}

let is_client_error: fn(Status) -> bool = fn(status: Status) -> bool {
    let code: i32 = status_code(status)
    return code >= 400 and code < 500
}

let is_server_error: fn(Status) -> bool = fn(status: Status) -> bool {
    let code: i32 = status_code(status)
    return code >= 500 and code < 600
}

// ============================================================================
// Functions (from src/headers.ki)
// ============================================================================

let get_header: fn(Headers, string) -> Option[string] =
    fn(headers: Headers, name: string) -> Option[string] {
        let lower_name: string = std.string.to_lower(name)
        return find_header_value(headers, lower_name)
    }

let find_header_value: fn(Headers, string) -> Option[string] =
    fn(headers: Headers, lower_name: string) -> Option[string] {
        var result: Option[string]
        match headers {
            Nil => { result = None }
            Cons(header, rest) => {
                let header_lower: string = std.string.to_lower(header.name)
                if header_lower == lower_name {
                    result = Some(header.value)
                } else {
                    result = find_header_value(rest, lower_name)
                }
            }
        }
        return result
    }

let set_header: fn(Headers, string, string) -> Headers =
    fn(headers: Headers, name: string, value: string) -> Headers {
        let without_existing: Headers = remove_header(headers, name)
        let new_header: Header = Header { name: name, value: value }
        return Cons(new_header, without_existing)
    }

let remove_header: fn(Headers, string) -> Headers =
    fn(headers: Headers, name: string) -> Headers {
        let lower_name: string = std.string.to_lower(name)
        return filter_headers(headers, lower_name)
    }

let filter_headers: fn(Headers, string) -> Headers =
    fn(headers: Headers, lower_name: string) -> Headers {
        var result: Headers
        match headers {
            Nil => { result = Nil }
            Cons(header, rest) => {
                let header_lower: string = std.string.to_lower(header.name)
                if header_lower == lower_name {
                    result = filter_headers(rest, lower_name)
                } else {
                    result = Cons(header, filter_headers(rest, lower_name))
                }
            }
        }
        return result
    }

let content_type: fn(string) -> Header = fn(value: string) -> Header {
    return Header { name: "Content-Type", value: value }
}

let authorization: fn(string) -> Header = fn(value: string) -> Header {
    return Header { name: "Authorization", value: value }
}

let accept: fn(string) -> Header = fn(value: string) -> Header {
    return Header { name: "Accept", value: value }
}

// ============================================================================
// Tests: Status code conversion
// ============================================================================

test "status_code returns 200 for OK" {
    assert(status_code(OK) == 200)
}

test "status_code returns 201 for Created" {
    assert(status_code(Created) == 201)
}

test "status_code returns 202 for Accepted" {
    assert(status_code(Accepted) == 202)
}

test "status_code returns 204 for NoContent" {
    assert(status_code(NoContent) == 204)
}

test "status_code returns 301 for MovedPermanently" {
    assert(status_code(MovedPermanently) == 301)
}

test "status_code returns 302 for Found" {
    assert(status_code(Found) == 302)
}

test "status_code returns 304 for NotModified" {
    assert(status_code(NotModified) == 304)
}

test "status_code returns 400 for BadRequest" {
    assert(status_code(BadRequest) == 400)
}

test "status_code returns 401 for Unauthorized" {
    assert(status_code(Unauthorized) == 401)
}

test "status_code returns 403 for Forbidden" {
    assert(status_code(Forbidden) == 403)
}

test "status_code returns 404 for NotFound" {
    assert(status_code(NotFound) == 404)
}

test "status_code returns 405 for MethodNotAllowed" {
    assert(status_code(MethodNotAllowed) == 405)
}

test "status_code returns 409 for Conflict" {
    assert(status_code(Conflict) == 409)
}

test "status_code returns 500 for InternalError" {
    assert(status_code(InternalError) == 500)
}

test "status_code returns 501 for NotImplemented" {
    assert(status_code(NotImplemented) == 501)
}

test "status_code returns 502 for BadGateway" {
    assert(status_code(BadGateway) == 502)
}

test "status_code returns 503 for ServiceUnavailable" {
    assert(status_code(ServiceUnavailable) == 503)
}

test "status_code returns custom value for Custom" {
    assert(status_code(Custom(418)) == 418)
}

test "status_code returns 307 for TemporaryRedirect" {
    assert(status_code(TemporaryRedirect) == 307)
}

test "status_code returns 308 for PermanentRedirect" {
    assert(status_code(PermanentRedirect) == 308)
}

test "status_from_code 307 returns TemporaryRedirect" {
    var matches: bool
    match status_from_code(307) {
        TemporaryRedirect => { matches = true }
        _ => { matches = false }
    }
    assert(matches)
}

test "status_from_code 308 returns PermanentRedirect" {
    var matches: bool
    match status_from_code(308) {
        PermanentRedirect => { matches = true }
        _ => { matches = false }
    }
    assert(matches)
}

test "is_redirect true for TemporaryRedirect" {
    assert(is_redirect(TemporaryRedirect) == true)
}

test "is_redirect true for PermanentRedirect" {
    assert(is_redirect(PermanentRedirect) == true)
}

// ============================================================================
// Tests: Status from code conversion
// ============================================================================

test "status_from_code 200 returns OK" {
    var matches: bool
    match status_from_code(200) {
        OK => { matches = true }
        _ => { matches = false }
    }
    assert(matches)
}

test "status_from_code 404 returns NotFound" {
    var matches: bool
    match status_from_code(404) {
        NotFound => { matches = true }
        _ => { matches = false }
    }
    assert(matches)
}

test "status_from_code 500 returns InternalError" {
    var matches: bool
    match status_from_code(500) {
        InternalError => { matches = true }
        _ => { matches = false }
    }
    assert(matches)
}

test "status_from_code unknown returns Custom" {
    var matches: bool
    match status_from_code(418) {
        Custom(418) => { matches = true }
        _ => { matches = false }
    }
    assert(matches)
}

// ============================================================================
// Tests: Round-trips
// ============================================================================

test "status_code roundtrip for OK" {
    let code: i32 = status_code(OK)
    var matches: bool
    match status_from_code(code) {
        OK => { matches = true }
        _ => { matches = false }
    }
    assert(matches)
}

test "status_code roundtrip for NotFound" {
    let code: i32 = status_code(NotFound)
    var matches: bool
    match status_from_code(code) {
        NotFound => { matches = true }
        _ => { matches = false }
    }
    assert(matches)
}

test "status_code roundtrip for Custom" {
    let code: i32 = status_code(Custom(418))
    var matches: bool
    match status_from_code(code) {
        Custom(418) => { matches = true }
        _ => { matches = false }
    }
    assert(matches)
}

// ============================================================================
// Tests: Status category checks
// ============================================================================

test "is_success true for OK" {
    assert(is_success(OK) == true)
}

test "is_success true for Created" {
    assert(is_success(Created) == true)
}

test "is_success true for NoContent" {
    assert(is_success(NoContent) == true)
}

test "is_success false for NotFound" {
    assert(is_success(NotFound) == false)
}

test "is_success false for InternalError" {
    assert(is_success(InternalError) == false)
}

test "is_redirect true for MovedPermanently" {
    assert(is_redirect(MovedPermanently) == true)
}

test "is_redirect true for Found" {
    assert(is_redirect(Found) == true)
}

test "is_redirect true for NotModified" {
    assert(is_redirect(NotModified) == true)
}

test "is_redirect false for OK" {
    assert(is_redirect(OK) == false)
}

test "is_client_error true for BadRequest" {
    assert(is_client_error(BadRequest) == true)
}

test "is_client_error true for Unauthorized" {
    assert(is_client_error(Unauthorized) == true)
}

test "is_client_error true for NotFound" {
    assert(is_client_error(NotFound) == true)
}

test "is_client_error false for OK" {
    assert(is_client_error(OK) == false)
}

test "is_client_error false for InternalError" {
    assert(is_client_error(InternalError) == false)
}

test "is_server_error true for InternalError" {
    assert(is_server_error(InternalError) == true)
}

test "is_server_error true for NotImplemented" {
    assert(is_server_error(NotImplemented) == true)
}

test "is_server_error true for BadGateway" {
    assert(is_server_error(BadGateway) == true)
}

test "is_server_error true for ServiceUnavailable" {
    assert(is_server_error(ServiceUnavailable) == true)
}

test "is_server_error false for OK" {
    assert(is_server_error(OK) == false)
}

test "is_server_error false for NotFound" {
    assert(is_server_error(NotFound) == false)
}

// ============================================================================
// Tests: Custom status category checks
// ============================================================================

test "is_success true for Custom 200" {
    assert(is_success(Custom(200)) == true)
}

test "is_success true for Custom 299" {
    assert(is_success(Custom(299)) == true)
}

test "is_redirect true for Custom 301" {
    assert(is_redirect(Custom(301)) == true)
}

test "is_client_error true for Custom 418" {
    assert(is_client_error(Custom(418)) == true)
}

test "is_server_error true for Custom 599" {
    assert(is_server_error(Custom(599)) == true)
}

// ============================================================================
// Tests: Header manipulation
// ============================================================================

test "get_header finds existing header" {
    let headers: Headers = Cons(
        Header { name: "Content-Type", value: "application/json" },
        Cons(
            Header { name: "Accept", value: "text/html" },
            Nil
        )
    )
    var found: bool
    match get_header(headers, "Content-Type") {
        Some(v) => { found = v == "application/json" }
        None => { found = false }
    }
    assert(found)
}

test "get_header is case insensitive" {
    let headers: Headers = Cons(
        Header { name: "Content-Type", value: "application/json" },
        Nil
    )
    var found: bool
    match get_header(headers, "content-type") {
        Some(v) => { found = v == "application/json" }
        None => { found = false }
    }
    assert(found)
}

test "get_header returns None for missing header" {
    let headers: Headers = Cons(
        Header { name: "Content-Type", value: "application/json" },
        Nil
    )
    var not_found: bool
    match get_header(headers, "Authorization") {
        Some(_) => { not_found = false }
        None => { not_found = true }
    }
    assert(not_found)
}

test "get_header returns None for empty list" {
    let headers: Headers = Nil
    var not_found: bool
    match get_header(headers, "Content-Type") {
        Some(_) => { not_found = false }
        None => { not_found = true }
    }
    assert(not_found)
}

test "set_header adds new header" {
    let headers: Headers = Nil
    let result: Headers = set_header(headers, "Content-Type", "application/json")
    var found: bool
    match get_header(result, "Content-Type") {
        Some(v) => { found = v == "application/json" }
        None => { found = false }
    }
    assert(found)
}

test "set_header replaces existing header" {
    let headers: Headers = Cons(
        Header { name: "Content-Type", value: "text/plain" },
        Nil
    )
    let result: Headers = set_header(headers, "Content-Type", "application/json")
    var found: bool
    match get_header(result, "Content-Type") {
        Some(v) => { found = v == "application/json" }
        None => { found = false }
    }
    assert(found)
}

test "remove_header removes existing header" {
    let headers: Headers = Cons(
        Header { name: "Content-Type", value: "application/json" },
        Cons(
            Header { name: "Accept", value: "text/html" },
            Nil
        )
    )
    let result: Headers = remove_header(headers, "Content-Type")
    var not_found: bool
    match get_header(result, "Content-Type") {
        Some(_) => { not_found = false }
        None => { not_found = true }
    }
    assert(not_found)
}

test "remove_header keeps other headers" {
    let headers: Headers = Cons(
        Header { name: "Content-Type", value: "application/json" },
        Cons(
            Header { name: "Accept", value: "text/html" },
            Nil
        )
    )
    let result: Headers = remove_header(headers, "Content-Type")
    var found: bool
    match get_header(result, "Accept") {
        Some(v) => { found = v == "text/html" }
        None => { found = false }
    }
    assert(found)
}

test "remove_header is case insensitive" {
    let headers: Headers = Cons(
        Header { name: "Content-Type", value: "application/json" },
        Nil
    )
    let result: Headers = remove_header(headers, "content-type")
    var not_found: bool
    match get_header(result, "Content-Type") {
        Some(_) => { not_found = false }
        None => { not_found = true }
    }
    assert(not_found)
}

test "remove_header handles non-existing header" {
    let headers: Headers = Cons(
        Header { name: "Content-Type", value: "application/json" },
        Nil
    )
    let result: Headers = remove_header(headers, "Authorization")
    var found: bool
    match get_header(result, "Content-Type") {
        Some(v) => { found = v == "application/json" }
        None => { found = false }
    }
    assert(found)
}

// ============================================================================
// Tests: Header helper functions
// ============================================================================

test "content_type creates correct header" {
    let header: Header = content_type("application/json")
    assert(header.name == "Content-Type")
    assert(header.value == "application/json")
}

test "authorization creates correct header" {
    let header: Header = authorization("Bearer token123")
    assert(header.name == "Authorization")
    assert(header.value == "Bearer token123")
}

test "accept creates correct header" {
    let header: Header = accept("text/html")
    assert(header.name == "Accept")
    assert(header.value == "text/html")
}
