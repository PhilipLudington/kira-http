let test_permanent_redirect_status_code: fn() -> void = fn() -> void {
    let response: Response = permanent_redirect("https://example.com")
    assert(status_code(response.status) == 301)
    return
}

// with_header tests

let test_with_header_adds_header: fn() -> void = fn() -> void {
    let response: Response = ok("body")
        |> with_header("X-Custom", "value")

    var has_custom: bool
    match get_header(response.headers, "X-Custom") {
        Some(v) => { has_custom = v == "value" }
        None => { has_custom = false }
    }
    assert(has_custom)
    return
}

let test_with_header_preserves_existing: fn() -> void = fn() -> void {
    let response: Response = ok("body")
        |> with_header("X-Custom", "value")

    var has_content_type: bool
    match get_header(response.headers, "Content-Type") {
        Some(v) => { has_content_type = v == "text/plain" }
        None => { has_content_type = false }
    }
    assert(has_content_type)
    return
}

// with_body tests

let test_with_body_changes_body: fn() -> void = fn() -> void {
    let response: Response = ok("original")
        |> with_body("modified")

    assert(response.body == "modified")
    return
}

let test_with_body_preserves_status: fn() -> void = fn() -> void {
    let response: Response = ok("original")
        |> with_body("modified")

    var matches: bool
    match response.status {
        OK => { matches = true }
        _ => { matches = false }
    }
    assert(matches)
    return
}

// with_status tests

let test_with_status_changes_status: fn() -> void = fn() -> void {
    let response: Response = ok("body")
        |> with_status(Created)

    var matches: bool
    match response.status {
        Created => { matches = true }
        _ => { matches = false }
    }
    assert(matches)
    return
}

let test_with_status_preserves_body: fn() -> void = fn() -> void {
    let response: Response = ok("original body")
        |> with_status(Created)

    assert(response.body == "original body")
    return
}

// chaining tests

let test_response_chaining: fn() -> void = fn() -> void {
    let response: Response = ok("initial")
        |> with_header("X-Request-Id", "123")
        |> with_body("final body")
        |> with_status(Created)

    var is_created: bool
    match response.status {
        Created => { is_created = true }
        _ => { is_created = false }
    }

    var has_request_id: bool
    match get_header(response.headers, "X-Request-Id") {
        Some(v) => { has_request_id = v == "123" }
        None => { has_request_id = false }
    }

    assert(is_created and has_request_id and response.body == "final body")
    return
}
