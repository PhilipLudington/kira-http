/// Integration tests for HTTP redirect following
///
/// These tests make real HTTP requests to httpbin.org to verify redirect
/// behavior end-to-end. Requires network access.
///
/// Note: Tests that need specific redirect status codes (301, 307, 308) use
/// httpbin.org/redirect-to with query parameters. Due to a known Kira v0.12.0
/// issue with url_decode in the module system, these tests construct Request
/// objects directly instead of using the builder's build() function.

import http.types.{Method, Status, Header, Headers, HttpError, QueryParam}
import http.request.{Request, RequestBuilder, new_request, with_header, with_body, with_max_redirects, build}
import http.response.{Response}
import http.status.{status_code}
import http.headers.{get_header}
import http.client.{get, send, request}

// ============================================================================
// Helper: construct a Request directly (bypasses build/url_decode)
// ============================================================================

let make_request: fn(Method, string, string, Headers, Option[string]) -> Request =
    fn(method: Method, url: string, path: string, headers: Headers, body: Option[string]) -> Request {
        return Request {
            method: method,
            url: url,
            path: path,
            headers: headers,
            body: body,
            query: Nil,
            path_params: Nil,
            timeout: None
        }
    }

// ============================================================================
// Tests: Basic redirect following (relative redirect URLs)
// ============================================================================

test "follows single 302 redirect" {
    let result: Result[Response, HttpError] = get("https://httpbin.org/redirect/1")
    match result {
        Ok(response) => {
            assert(status_code(response.status) == 200, "Expected 200 after redirect")
        }
        Err(_) => {
            assert(false, "Request should succeed after redirect")
        }
    }
}

test "follows chain of 3 redirects" {
    let result: Result[Response, HttpError] = get("https://httpbin.org/redirect/3")
    match result {
        Ok(response) => {
            assert(status_code(response.status) == 200, "Expected 200 after 3 redirects")
        }
        Err(_) => {
            assert(false, "Request should succeed after 3 redirects")
        }
    }
}

test "follows chain of 5 redirects" {
    let result: Result[Response, HttpError] = get("https://httpbin.org/redirect/5")
    match result {
        Ok(response) => {
            assert(status_code(response.status) == 200, "Expected 200 after 5 redirects")
        }
        Err(_) => {
            assert(false, "Request should succeed after 5 redirects")
        }
    }
}

