/// Tests for kira-http response module
///
/// Tests response helper functions and correct status codes and headers.

module http.tests.test_response

use http.types.Status
use http.types.Header
use http.types.Headers
use http.response.Response
use http.response.ok
use http.response.created
use http.response.no_content
use http.response.bad_request
use http.response.unauthorized
use http.response.forbidden
use http.response.not_found
use http.response.method_not_allowed
use http.response.conflict
use http.response.internal_error
use http.response.service_unavailable
use http.response.json_response
use http.response.json_ok
use http.response.json_created
use http.response.redirect
use http.response.permanent_redirect
use http.response.with_header
use http.response.with_body
use http.response.with_status
use http.headers.get_header
use http.status.status_code

// ok tests

let test_ok_status: fn() -> void = fn() -> void {
    let response: Response = ok("Hello")
    var matches: bool
    match response.status {
        OK => { matches = true }
        _ => { matches = false }
    }
    assert(matches)
    return
}

let test_ok_body: fn() -> void = fn() -> void {
    let response: Response = ok("Hello, World!")
    assert(response.body == "Hello, World!")
    return
}

let test_ok_content_type: fn() -> void = fn() -> void {
    let response: Response = ok("Hello")
    var has_content_type: bool
    match get_header(response.headers, "Content-Type") {
        Some(v) => { has_content_type = v == "text/plain" }
        None => { has_content_type = false }
    }
    assert(has_content_type)
    return
}

