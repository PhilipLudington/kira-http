/// Tests for the HTTP client module
///
/// These tests verify the client functions handle requests correctly,
/// including error conditions like invalid URLs and connection failures.

module tests.test_client

import http.client.{get, post, put, patch, delete, head, options, request, send, post_json, put_json, patch_json}
import http.request.{Request, RequestBuilder, new_request, with_header, with_body, with_timeout, build}
import http.response.{Response}
import http.types.{Method, Status, HttpError, Headers}

test "get rejects empty URL" {
    let result: Result[Response, HttpError] = get("")

    var is_invalid_url: bool
    match result {
        Ok(_) => { is_invalid_url = false }
        Err(InvalidUrl(_)) => { is_invalid_url = true }
        Err(_) => { is_invalid_url = false }
    }

    assert(is_invalid_url, "Empty URL should return InvalidUrl error")
}

test "get rejects invalid scheme" {
    let result: Result[Response, HttpError] = get("ftp://example.com")

    var is_invalid_url: bool
    match result {
        Ok(_) => { is_invalid_url = false }
        Err(InvalidUrl(_)) => { is_invalid_url = true }
        Err(_) => { is_invalid_url = false }
    }

    assert(is_invalid_url, "FTP URL should return InvalidUrl error")
}

test "get rejects malformed URL" {
    let result: Result[Response, HttpError] = get("not-a-url")

    var is_invalid_url: bool
    match result {
        Ok(_) => { is_invalid_url = false }
        Err(InvalidUrl(_)) => { is_invalid_url = true }
        Err(_) => { is_invalid_url = false }
    }

    assert(is_invalid_url, "Malformed URL should return InvalidUrl error")
}

test "post builds request with body" {
    // Test that the request builder works correctly
    let b1: RequestBuilder = new_request(POST, "https://example.com/api")
    let builder: RequestBuilder = with_body(b1, "test body")

    let req: Request = build(builder)

    var is_post: bool
    match req.method {
        POST => { is_post = true }
        _ => { is_post = false }
    }
    assert(is_post, "Method should be POST")
    assert(req.url == "https://example.com/api", "URL should match")

    var has_body: bool
    match req.body {
        Some(b) => { has_body = b == "test body" }
        None => { has_body = false }
    }
    assert(has_body, "Body should be set")
}

test "put builds request with body" {
    let b1: RequestBuilder = new_request(PUT, "https://example.com/api/1")
    let builder: RequestBuilder = with_body(b1, "updated data")

    let req: Request = build(builder)

    var is_put: bool
    match req.method {
        PUT => { is_put = true }
        _ => { is_put = false }
    }
    assert(is_put, "Method should be PUT")

    var has_body: bool
    match req.body {
        Some(b) => { has_body = b == "updated data" }
        None => { has_body = false }
    }
    assert(has_body, "Body should be set")
}

test "delete builds request without body" {
    let builder: RequestBuilder = new_request(DELETE, "https://example.com/api/1")
    let req: Request = build(builder)

    var is_delete: bool
    match req.method {
        DELETE => { is_delete = true }
        _ => { is_delete = false }
    }
    assert(is_delete, "Method should be DELETE")

    var has_no_body: bool
    match req.body {
        Some(_) => { has_no_body = false }
        None => { has_no_body = true }
    }
    assert(has_no_body, "DELETE should have no body by default")
}

test "request builder with headers" {
    let b1: RequestBuilder = new_request(GET, "https://example.com/api")
    let b2: RequestBuilder = with_header(b1, "Authorization", "Bearer token123")
    let builder: RequestBuilder = with_header(b2, "Accept", "application/json")

    let req: Request = build(builder)

    // Check that headers were added
    var has_auth: bool = false
    var has_accept: bool = false
    var headers: Headers = req.headers

    match headers {
        Nil => { }
        Cons(h, rest) => {
            if h.name == "Authorization" and h.value == "Bearer token123" {
                has_auth = true
            }
            if h.name == "Accept" and h.value == "application/json" {
                has_accept = true
            }
            match rest {
                Nil => { }
                Cons(h2, _) => {
                    if h2.name == "Authorization" and h2.value == "Bearer token123" {
                        has_auth = true
                    }
                    if h2.name == "Accept" and h2.value == "application/json" {
                        has_accept = true
                    }
                }
            }
        }
    }

    assert(has_auth, "Should have Authorization header")
    assert(has_accept, "Should have Accept header")
}

test "request builder with timeout" {
    let b1: RequestBuilder = new_request(GET, "https://example.com/api")
    let builder: RequestBuilder = with_timeout(b1, 5000)

    var has_timeout: bool
    match builder.timeout {
        Some(t) => { has_timeout = t == 5000 }
        None => { has_timeout = false }
    }

    assert(has_timeout, "Timeout should be set to 5000ms")
}

test "post_json sets content type" {
    let b1: RequestBuilder = new_request(POST, "https://example.com/api")
    let b2: RequestBuilder = with_header(b1, "Content-Type", "application/json")
    let builder: RequestBuilder = with_body(b2, "{\"name\": \"test\"}")

    let req: Request = build(builder)

    var has_json_content_type: bool = false
    var headers: Headers = req.headers

    match headers {
        Nil => { }
        Cons(h, rest) => {
            if h.name == "Content-Type" and h.value == "application/json" {
                has_json_content_type = true
            }
            match rest {
                Nil => { }
                Cons(h2, _) => {
                    if h2.name == "Content-Type" and h2.value == "application/json" {
                        has_json_content_type = true
                    }
                }
            }
        }
    }

    assert(has_json_content_type, "Should have application/json content type")
}

test "head request has correct method" {
    let builder: RequestBuilder = new_request(HEAD, "https://example.com")
    let req: Request = build(builder)

    var is_head: bool
    match req.method {
        HEAD => { is_head = true }
        _ => { is_head = false }
    }
    assert(is_head, "Method should be HEAD")
}

test "options request has correct method" {
    let builder: RequestBuilder = new_request(OPTIONS, "https://example.com")
    let req: Request = build(builder)

    var is_options: bool
    match req.method {
        OPTIONS => { is_options = true }
        _ => { is_options = false }
    }
    assert(is_options, "Method should be OPTIONS")
}

test "patch builds request with body" {
    let b1: RequestBuilder = new_request(PATCH, "https://example.com/api/1")
    let builder: RequestBuilder = with_body(b1, "{\"field\": \"value\"}")

    let req: Request = build(builder)

    var is_patch: bool
    match req.method {
        PATCH => { is_patch = true }
        _ => { is_patch = false }
    }
    assert(is_patch, "Method should be PATCH")

    var has_body: bool
    match req.body {
        Some(b) => { has_body = b == "{\"field\": \"value\"}" }
        None => { has_body = false }
    }
    assert(has_body, "PATCH should have body")
}

test "valid http URL" {
    // Build a request with a valid HTTP URL
    let builder: RequestBuilder = new_request(GET, "http://example.com/path")
    let req: Request = build(builder)

    // URL validation happens at the request level
    let has_valid_scheme: bool = std.string.starts_with(req.url, "http://")
    assert(has_valid_scheme, "HTTP URLs should be valid")
}

test "valid https URL" {
    let builder: RequestBuilder = new_request(GET, "https://example.com/path")
    let req: Request = build(builder)

    let has_valid_scheme: bool = std.string.starts_with(req.url, "https://")
    assert(has_valid_scheme, "HTTPS URLs should be valid")
}

test "chained builder operations" {
    let b1: RequestBuilder = new_request(POST, "https://api.example.com/users")
    let b2: RequestBuilder = with_header(b1, "Content-Type", "application/json")
    let b3: RequestBuilder = with_header(b2, "Authorization", "Bearer abc123")
    let b4: RequestBuilder = with_body(b3, "{\"name\": \"Alice\"}")
    let builder: RequestBuilder = with_timeout(b4, 10000)

    let req: Request = build(builder)

    var is_post: bool
    match req.method {
        POST => { is_post = true }
        _ => { is_post = false }
    }
    assert(is_post, "Method should be POST")
    assert(req.url == "https://api.example.com/users", "URL should match")

    var has_body: bool
    match req.body {
        Some(b) => { has_body = b == "{\"name\": \"Alice\"}" }
        None => { has_body = false }
    }
    assert(has_body, "Body should be set")

    var has_timeout: bool
    match builder.timeout {
        Some(t) => { has_timeout = t == 10000 }
        None => { has_timeout = false }
    }
    assert(has_timeout, "Timeout should be set")
}
