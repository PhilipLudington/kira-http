test "follows chain of absolute redirects" {
    let result: Result[Response, HttpError] = get("https://httpbin.org/absolute-redirect/3")
    match result {
        Ok(response) => {
            assert(status_code(response.status) == 200, "Expected 200 after 3 absolute redirects")
