    }
    assert(has_json_type)
    return
}

let test_json_response_with_error_status: fn() -> void = fn() -> void {
    let response: Response = json_response(BadRequest, "{\"error\": \"bad\"}")
    var matches: bool
    match response.status {
        BadRequest => { matches = true }
        _ => { matches = false }
    }
    assert(matches)
    return
}

