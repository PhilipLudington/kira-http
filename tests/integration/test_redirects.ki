}

// ============================================================================
// Tests: TooManyRedirects
// ============================================================================

test "returns TooManyRedirects for redirect chain exceeding default limit" {
    let result: Result[Response, HttpError] = get("https://httpbin.org/redirect/20")
    match result {
        Ok(_) => {
            assert(false, "Should have returned TooManyRedirects")
        }
        Err(error) => {
            match error {
                TooManyRedirects => {
                    assert(true)
                }
                _ => {
                    assert(false, "Expected TooManyRedirects error")
                }
            }
        }
    }
}

test "returns TooManyRedirects with custom limit of 2" {
    let b1: RequestBuilder = new_request(GET, "https://httpbin.org/redirect/5")
    let builder: RequestBuilder = with_max_redirects(b1, 2)
    let result: Result[Response, HttpError] = send(builder)
    match result {
        Ok(_) => {
            assert(false, "Should have returned TooManyRedirects")
        }
        Err(error) => {
            match error {
                TooManyRedirects => {
                    assert(true)
                }
                _ => {
                    assert(false, "Expected TooManyRedirects error")
                }
            }
        }
    }
}

test "max_redirects zero disables redirect following" {
    let b1: RequestBuilder = new_request(GET, "https://httpbin.org/redirect/1")
    let builder: RequestBuilder = with_max_redirects(b1, 0)
    let result: Result[Response, HttpError] = send(builder)
    match result {
        Ok(_) => {
            assert(false, "Should have returned TooManyRedirects with max_redirects=0")
        }
        Err(error) => {
            match error {
                TooManyRedirects => {
                    assert(true)
                }
                _ => {
                    assert(false, "Expected TooManyRedirects error")
                }
            }
        }
    }
}

// ============================================================================
// Tests: Redirect with specific status codes
// Uses direct Request construction to bypass url_decode module issue
// ============================================================================

test "follows 301 redirect" {
    let req: Request = make_request(
        GET,
        "https://httpbin.org/redirect-to?url=https://httpbin.org/get&status_code=301",
        "/redirect-to",
        Nil,
        None
    )
    let result: Result[Response, HttpError] = request(req)
    match result {
        Ok(response) => {
            assert(status_code(response.status) == 200, "Expected 200 after 301 redirect")
        }
        Err(_) => {
            assert(false, "Request should succeed after 301 redirect")
        }
    }
}

test "follows 307 redirect" {
    let req: Request = make_request(
        GET,
        "https://httpbin.org/redirect-to?url=https://httpbin.org/get&status_code=307",
