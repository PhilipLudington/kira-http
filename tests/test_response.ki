/// Tests for kira-http response module
///
/// Tests response helper functions and correct status codes and headers.

module http.tests.test_response

import http.types.{Status, Header, Headers}
import http.response.{Response, ok, created, no_content, bad_request, unauthorized, forbidden, not_found, method_not_allowed, conflict, internal_error, service_unavailable, json_response, json_ok, json_created, redirect, permanent_redirect, with_header, with_body, with_status}
import http.headers.{get_header}
import http.status.{status_code}

// ok tests

test "ok sets OK status" {
    let response: Response = ok("Hello")
    var matches: bool
    match response.status {
        OK => { matches = true }
        _ => { matches = false }
    }
    assert(matches)
}

test "ok sets body" {
    let response: Response = ok("Hello, World!")
    assert(response.body == "Hello, World!")
}

test "ok sets content type" {
    let response: Response = ok("Hello")
    var has_content_type: bool
    match get_header(response.headers, "Content-Type") {
        Some(v) => { has_content_type = v == "text/plain" }
        None => { has_content_type = false }
    }
    assert(has_content_type)
}

// created tests

test "created sets Created status" {
    let response: Response = created("{\"id\": 1}")
    var matches: bool
    match response.status {
        Created => { matches = true }
        _ => { matches = false }
    }
    assert(matches)
}

test "created sets body" {
    let response: Response = created("{\"id\": 1}")
    assert(response.body == "{\"id\": 1}")
}

test "created sets content type" {
    let response: Response = created("body")
    var has_content_type: bool
    match get_header(response.headers, "Content-Type") {
        Some(v) => { has_content_type = v == "text/plain" }
        None => { has_content_type = false }
    }
    assert(has_content_type)
}

// no_content tests

test "no_content sets NoContent status" {
    let response: Response = no_content()
    var matches: bool
    match response.status {
        NoContent => { matches = true }
        _ => { matches = false }
    }
    assert(matches)
}

test "no_content has empty body" {
    let response: Response = no_content()
    assert(response.body == "")
}

test "no_content has no headers" {
    let response: Response = no_content()
    var is_empty: bool
    match response.headers {
        Nil => { is_empty = true }
        Cons(_, _) => { is_empty = false }
    }
    assert(is_empty)
}

// bad_request tests

test "bad_request sets BadRequest status" {
    let response: Response = bad_request("Invalid input")
    var matches: bool
    match response.status {
        BadRequest => { matches = true }
        _ => { matches = false }
    }
    assert(matches)
}

test "bad_request sets body" {
    let response: Response = bad_request("Invalid input")
    assert(response.body == "Invalid input")
}

test "bad_request returns 400 status code" {
    let response: Response = bad_request("error")
    assert(status_code(response.status) == 400)
}

