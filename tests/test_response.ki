// redirect tests

test "redirect sets Found status" {
    let response: Response = redirect("https://example.com")
    var matches: bool
    match response.status {
        Found => { matches = true }
        _ => { matches = false }
    }
    assert(matches)
}

test "redirect sets Location header" {
    let response: Response = redirect("https://example.com/new")
    var has_location: bool
    match get_header(response.headers, "Location") {
        Some(v) => { has_location = v == "https://example.com/new" }
        None => { has_location = false }
    }
    assert(has_location)
}

test "redirect has empty body" {
    let response: Response = redirect("https://example.com")
    assert(response.body == "")
}

test "redirect returns 302 status code" {
    let response: Response = redirect("https://example.com")
    assert(status_code(response.status) == 302)
}

// permanent_redirect tests

test "permanent_redirect sets MovedPermanently status" {
    let response: Response = permanent_redirect("https://example.com")
    var matches: bool
    match response.status {
        MovedPermanently => { matches = true }
        _ => { matches = false }
    }
    assert(matches)
}

test "permanent_redirect sets Location header" {
    let response: Response = permanent_redirect("https://example.com/new")
    var has_location: bool
    match get_header(response.headers, "Location") {
        Some(v) => { has_location = v == "https://example.com/new" }
        None => { has_location = false }
    }
    assert(has_location)
}

test "permanent_redirect returns 301 status code" {
    let response: Response = permanent_redirect("https://example.com")
    assert(status_code(response.status) == 301)
}

// with_header tests

test "with_header adds header" {
    let response: Response = with_header(ok("body"), "X-Custom", "value")

    var has_custom: bool
    match get_header(response.headers, "X-Custom") {
        Some(v) => { has_custom = v == "value" }
        None => { has_custom = false }
    }
    assert(has_custom)
}

test "with_header preserves existing headers" {
    let response: Response = with_header(ok("body"), "X-Custom", "value")

    var has_content_type: bool
    match get_header(response.headers, "Content-Type") {
        Some(v) => { has_content_type = v == "text/plain" }
        None => { has_content_type = false }
    }
    assert(has_content_type)
}

// with_body tests

test "with_body changes body" {
    let response: Response = with_body(ok("original"), "modified")

    assert(response.body == "modified")
}

test "with_body preserves status" {
    let response: Response = with_body(ok("original"), "modified")

    var matches: bool
    match response.status {
        OK => { matches = true }
        _ => { matches = false }
    }
    assert(matches)
}

// with_status tests

test "with_status changes status" {
    let response: Response = with_status(ok("body"), Created)

    var matches: bool
    match response.status {
        Created => { matches = true }
        _ => { matches = false }
    }
    assert(matches)
}

test "with_status preserves body" {
    let response: Response = with_status(ok("original body"), Created)

    assert(response.body == "original body")
}

// chaining tests

test "response chaining works" {
    let r1: Response = ok("initial")
    let r2: Response = with_header(r1, "X-Request-Id", "123")
    let r3: Response = with_body(r2, "final body")
    let response: Response = with_status(r3, Created)

    var is_created: bool
    match response.status {
        Created => { is_created = true }
        _ => { is_created = false }
    }

    var has_request_id: bool
    match get_header(response.headers, "X-Request-Id") {
        Some(v) => { has_request_id = v == "123" }
        None => { has_request_id = false }
    }

    assert(is_created and has_request_id and response.body == "final body")
}
