}

let test_is_server_error_internal_error: fn() -> void = fn() -> void {
    assert(is_server_error(InternalError) == true)
    return
}

let test_is_server_error_not_implemented: fn() -> void = fn() -> void {
    assert(is_server_error(NotImplemented) == true)
