// Header manipulation tests

let test_get_header_existing: fn() -> void = fn() -> void {
    let headers: Headers = Cons(
        Header { name: "Content-Type", value: "application/json" },
        Cons(
            Header { name: "Accept", value: "text/html" },
            Nil
        )
    )
    var found: bool
    match get_header(headers, "Content-Type") {
        Some(v) => { found = v == "application/json" }
        None => { found = false }
    }
    assert(found)
    return
}

let test_get_header_case_insensitive: fn() -> void = fn() -> void {
    let headers: Headers = Cons(
        Header { name: "Content-Type", value: "application/json" },
        Nil
    )
    var found: bool
    match get_header(headers, "content-type") {
        Some(v) => { found = v == "application/json" }
        None => { found = false }
    }
    assert(found)
    return
}

let test_get_header_not_found: fn() -> void = fn() -> void {
    let headers: Headers = Cons(
        Header { name: "Content-Type", value: "application/json" },
        Nil
    )
    var not_found: bool
    match get_header(headers, "Authorization") {
        Some(_) => { not_found = false }
        None => { not_found = true }
    }
    assert(not_found)
    return
}

let test_get_header_empty_list: fn() -> void = fn() -> void {
    let headers: Headers = Nil
    var not_found: bool
    match get_header(headers, "Content-Type") {
        Some(_) => { not_found = false }
        None => { not_found = true }
    }
    assert(not_found)
    return
}

let test_set_header_new: fn() -> void = fn() -> void {
    let headers: Headers = Nil
    let result: Headers = set_header(headers, "Content-Type", "application/json")
    var found: bool
    match get_header(result, "Content-Type") {
        Some(v) => { found = v == "application/json" }
        None => { found = false }
    }
    assert(found)
    return
}

let test_set_header_replace: fn() -> void = fn() -> void {
    let headers: Headers = Cons(
        Header { name: "Content-Type", value: "text/plain" },
        Nil
    )
    let result: Headers = set_header(headers, "Content-Type", "application/json")
    var found: bool
    match get_header(result, "Content-Type") {
        Some(v) => { found = v == "application/json" }
        None => { found = false }
    }
    assert(found)
    return
}

let test_remove_header_existing: fn() -> void = fn() -> void {
    let headers: Headers = Cons(
        Header { name: "Content-Type", value: "application/json" },
        Cons(
            Header { name: "Accept", value: "text/html" },
            Nil
        )
    )
    let result: Headers = remove_header(headers, "Content-Type")
    var not_found: bool
    match get_header(result, "Content-Type") {
        Some(_) => { not_found = false }
        None => { not_found = true }
    }
    assert(not_found)
    return
}

let test_remove_header_keeps_others: fn() -> void = fn() -> void {
    let headers: Headers = Cons(
        Header { name: "Content-Type", value: "application/json" },
        Cons(
            Header { name: "Accept", value: "text/html" },
            Nil
        )
    )
    let result: Headers = remove_header(headers, "Content-Type")
    var found: bool
    match get_header(result, "Accept") {
        Some(v) => { found = v == "text/html" }
        None => { found = false }
    }
    assert(found)
    return
}

let test_remove_header_case_insensitive: fn() -> void = fn() -> void {
    let headers: Headers = Cons(
        Header { name: "Content-Type", value: "application/json" },
        Nil
    )
    let result: Headers = remove_header(headers, "content-type")
    var not_found: bool
    match get_header(result, "Content-Type") {
        Some(_) => { not_found = false }
        None => { not_found = true }
    }
    assert(not_found)
    return
}

let test_remove_header_not_existing: fn() -> void = fn() -> void {
    let headers: Headers = Cons(
        Header { name: "Content-Type", value: "application/json" },
        Nil
    )
    let result: Headers = remove_header(headers, "Authorization")
    var found: bool
    match get_header(result, "Content-Type") {
        Some(v) => { found = v == "application/json" }
        None => { found = false }
    }
    assert(found)
    return
}

// Header helper function tests

let test_content_type_creates_header: fn() -> void = fn() -> void {
    let header: Header = content_type("application/json")
    assert(header.name == "Content-Type")
    assert(header.value == "application/json")
    return
}

let test_authorization_creates_header: fn() -> void = fn() -> void {
    let header: Header = authorization("Bearer token123")
    assert(header.name == "Authorization")
    assert(header.value == "Bearer token123")
    return
}

let test_accept_creates_header: fn() -> void = fn() -> void {
    let header: Header = accept("text/html")
    assert(header.name == "Accept")
    assert(header.value == "text/html")
    return
}
