let test_parse_url_port_out_of_range: fn() -> void = fn() -> void {
    let result: Result[Url, HttpError] = parse_url("https://example.com:70000/path")
    var is_error: bool
    match result {
        Ok(_) => { is_error = false }
        Err(_) => { is_error = true }
