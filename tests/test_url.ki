/// Tests for kira-http URL utilities
///
/// Tests URL parsing, URL building round-trips, query parameter extraction,
/// path parameter extraction, and invalid URL handling.

module http.tests.test_url

import http.types.{HttpError, QueryParam}
import http.url.{Url, parse_url, build_url, parse_query_string, get_query_param, get_query_params, extract_path_param, path_matches}

// URL parsing tests - various schemes

test "parse_url parses https scheme" {
    let result: Result[Url, HttpError] = parse_url("https://example.com/path")
    var is_valid: bool
    match result {
        Ok(url) => {
            is_valid = url.scheme == "https" and url.host == "example.com" and url.path == "/path"
        }
        Err(_) => { is_valid = false }
    }
    assert(is_valid)
}

test "parse_url parses http scheme" {
    let result: Result[Url, HttpError] = parse_url("http://example.com")
    var is_valid: bool
    match result {
        Ok(url) => {
            is_valid = url.scheme == "http" and url.host == "example.com"
        }
        Err(_) => { is_valid = false }
    }
    assert(is_valid)
}

test "parse_url parses ftp scheme" {
    let result: Result[Url, HttpError] = parse_url("ftp://files.example.com/download")
    var is_valid: bool
    match result {
        Ok(url) => {
            is_valid = url.scheme == "ftp" and url.host == "files.example.com"
        }
        Err(_) => { is_valid = false }
    }
    assert(is_valid)
}

// URL parsing tests - with port

test "parse_url extracts port 8080" {
    let result: Result[Url, HttpError] = parse_url("https://example.com:8080/api")
    var is_valid: bool
    match result {
        Ok(url) => {
            match url.port {
                Some(p) => { is_valid = p == 8080 }
                None => { is_valid = false }
            }
        }
        Err(_) => { is_valid = false }
    }
    assert(is_valid)
}

test "parse_url extracts port 443" {
    let result: Result[Url, HttpError] = parse_url("https://example.com:443")
    var is_valid: bool
    match result {
        Ok(url) => {
            match url.port {
                Some(p) => { is_valid = p == 443 }
                None => { is_valid = false }
            }
        }
        Err(_) => { is_valid = false }
    }
    assert(is_valid)
}

test "parse_url has None port when not specified" {
    let result: Result[Url, HttpError] = parse_url("https://example.com/path")
    var is_valid: bool
    match result {
        Ok(url) => {
            match url.port {
                Some(_) => { is_valid = false }
                None => { is_valid = true }
            }
        }
        Err(_) => { is_valid = false }
    }
    assert(is_valid)
}

// URL parsing tests - with path

test "parse_url extracts simple path" {
    let result: Result[Url, HttpError] = parse_url("https://example.com/users")
    var is_valid: bool
    match result {
        Ok(url) => { is_valid = url.path == "/users" }
        Err(_) => { is_valid = false }
    }
    assert(is_valid)
}

test "parse_url extracts nested path" {
    let result: Result[Url, HttpError] = parse_url("https://example.com/api/v1/users")
    var is_valid: bool
    match result {
        Ok(url) => { is_valid = url.path == "/api/v1/users" }
        Err(_) => { is_valid = false }
    }
    assert(is_valid)
}

test "parse_url defaults to / for no path" {
    let result: Result[Url, HttpError] = parse_url("https://example.com")
    var is_valid: bool
    match result {
        Ok(url) => { is_valid = url.path == "/" }
        Err(_) => { is_valid = false }
    }
    assert(is_valid)
}

test "parse_url handles root path" {
    let result: Result[Url, HttpError] = parse_url("https://example.com/")
    var is_valid: bool
    match result {
        Ok(url) => { is_valid = url.path == "/" }
        Err(_) => { is_valid = false }
    }
    assert(is_valid)
}

// URL parsing tests - with query

test "parse_url extracts query string" {
    let result: Result[Url, HttpError] = parse_url("https://example.com/search?q=kira")
    var is_valid: bool
    match result {
        Ok(url) => {
            match url.query {
                Some(q) => { is_valid = q == "q=kira" }
                None => { is_valid = false }
            }
        }
        Err(_) => { is_valid = false }
    }
    assert(is_valid)
}

test "parse_url extracts multiple query params" {
    let result: Result[Url, HttpError] = parse_url("https://example.com/search?q=kira&limit=10")
    var is_valid: bool
    match result {
        Ok(url) => {
            match url.query {
                Some(q) => { is_valid = q == "q=kira&limit=10" }
                None => { is_valid = false }
            }
        }
        Err(_) => { is_valid = false }
    }
    assert(is_valid)
}

test "parse_url has None query when not specified" {
    let result: Result[Url, HttpError] = parse_url("https://example.com/path")
    var is_valid: bool
    match result {
        Ok(url) => {
            match url.query {
                Some(_) => { is_valid = false }
                None => { is_valid = true }
            }
        }
        Err(_) => { is_valid = false }
    }
    assert(is_valid)
}

// URL parsing tests - with fragment

test "parse_url extracts fragment" {
    let result: Result[Url, HttpError] = parse_url("https://example.com/page#section")
    var is_valid: bool
    match result {
        Ok(url) => {
            match url.fragment {
                Some(f) => { is_valid = f == "section" }
                None => { is_valid = false }
            }
        }
        Err(_) => { is_valid = false }
    }
    assert(is_valid)
}

test "parse_url has None fragment when not specified" {
    let result: Result[Url, HttpError] = parse_url("https://example.com/path")
    var is_valid: bool
    match result {
        Ok(url) => {
            match url.fragment {
                Some(_) => { is_valid = false }
                None => { is_valid = true }
            }
        }
        Err(_) => { is_valid = false }
    }
    assert(is_valid)
}

// URL parsing tests - complete URL

test "parse_url parses complete URL" {
    let result: Result[Url, HttpError] = parse_url("https://api.example.com:8080/v1/users?id=123#details")
    var is_valid: bool
    match result {
        Ok(url) => {
            var port_valid: bool
            match url.port {
                Some(p) => { port_valid = p == 8080 }
                None => { port_valid = false }
            }
            var query_valid: bool
            match url.query {
                Some(q) => { query_valid = q == "id=123" }
                None => { query_valid = false }
            }
            var fragment_valid: bool
            match url.fragment {
                Some(f) => { fragment_valid = f == "details" }
                None => { fragment_valid = false }
            }
            is_valid = url.scheme == "https" and
                       url.host == "api.example.com" and
                       port_valid and
                       url.path == "/v1/users" and
                       query_valid and
                       fragment_valid
        }
        Err(_) => { is_valid = false }
    }
    assert(is_valid)
}

// URL building tests - round-trips

test "build_url creates simple URL" {
    let url: Url = Url {
        scheme: "https",
        host: "example.com",
        port: None,
        path: "/",
        query: None,
        fragment: None
    }
    let result: string = build_url(url)
    assert(result == "https://example.com/")
}

test "build_url includes port" {
    let url: Url = Url {
        scheme: "https",
        host: "example.com",
        port: Some(8080),
        path: "/api",
        query: None,
        fragment: None
    }
    let result: string = build_url(url)
    assert(result == "https://example.com:8080/api")
}

test "build_url includes query" {
    let url: Url = Url {
        scheme: "https",
        host: "example.com",
        port: None,
        path: "/search",
        query: Some("q=kira"),
        fragment: None
    }
    let result: string = build_url(url)
    assert(result == "https://example.com/search?q=kira")
}

test "build_url includes fragment" {
    let url: Url = Url {
        scheme: "https",
        host: "example.com",
        port: None,
        path: "/page",
        query: None,
        fragment: Some("section")
    }
    let result: string = build_url(url)
    assert(result == "https://example.com/page#section")
}

test "build_url creates complete URL" {
    let url: Url = Url {
        scheme: "https",
        host: "api.example.com",
        port: Some(8080),
        path: "/v1/users",
        query: Some("id=123"),
        fragment: Some("details")
    }
    let result: string = build_url(url)
    assert(result == "https://api.example.com:8080/v1/users?id=123#details")
}

test "parse and build roundtrip preserves URL" {
    let original: string = "https://example.com:8080/path?query=value#fragment"
    let parse_result: Result[Url, HttpError] = parse_url(original)
    var is_valid: bool
    match parse_result {
        Ok(url) => {
            let rebuilt: string = build_url(url)
            is_valid = rebuilt == original
        }
        Err(_) => { is_valid = false }
    }
    assert(is_valid)
}

test "parse and build roundtrip for minimal URL" {
    let original: string = "http://localhost/"
    let parse_result: Result[Url, HttpError] = parse_url(original)
    var is_valid: bool
    match parse_result {
        Ok(url) => {
            let rebuilt: string = build_url(url)
            is_valid = rebuilt == original
        }
        Err(_) => { is_valid = false }
    }
    assert(is_valid)
}

// Query parameter extraction tests

test "parse_query_string parses single param" {
    let params: List[QueryParam] = parse_query_string("key=value")
    var is_valid: bool
    match params {
        Cons(param, Nil) => {
            is_valid = param.key == "key" and param.value == "value"
        }
        _ => { is_valid = false }
    }
    assert(is_valid)
}

test "parse_query_string parses multiple params" {
    let params: List[QueryParam] = parse_query_string("a=1&b=2&c=3")
    var count: i32 = 0
    var current: List[QueryParam] = params
    var continue_loop: bool = true
    while continue_loop {
        match current {
            Cons(_, rest) => {
                count = count + 1
                current = rest
            }
            Nil => {
                continue_loop = false
            }
        }
    }
    assert(count == 3)
}

test "parse_query_string handles empty string" {
    let params: List[QueryParam] = parse_query_string("")
    var is_empty: bool
    match params {
        Nil => { is_empty = true }
        Cons(_, _) => { is_empty = false }
    }
    assert(is_empty)
}

test "parse_query_string handles key without value" {
    let params: List[QueryParam] = parse_query_string("flag")
    var is_valid: bool
    match params {
        Cons(param, Nil) => {
            is_valid = param.key == "flag" and param.value == ""
        }
        _ => { is_valid = false }
    }
    assert(is_valid)
}

test "get_query_param finds existing param" {
    let params: List[QueryParam] = parse_query_string("name=kira&version=1")
    let result: Option[string] = get_query_param(params, "name")
    var is_valid: bool
    match result {
        Some(v) => { is_valid = v == "kira" }
        None => { is_valid = false }
    }
    assert(is_valid)
}

test "get_query_param returns None for missing param" {
    let params: List[QueryParam] = parse_query_string("name=kira")
    let result: Option[string] = get_query_param(params, "missing")
    var is_not_found: bool
    match result {
        Some(_) => { is_not_found = false }
        None => { is_not_found = true }
    }
    assert(is_not_found)
}

test "get_query_params finds multiple values" {
    let params: List[QueryParam] = parse_query_string("tag=a&tag=b&tag=c")
    let result: List[string] = get_query_params(params, "tag")
    var count: i32 = 0
    var current: List[string] = result
    var continue_loop: bool = true
    while continue_loop {
        match current {
            Cons(_, rest) => {
                count = count + 1
                current = rest
            }
            Nil => {
                continue_loop = false
            }
        }
    }
    assert(count == 3)
}

test "get_query_params returns single value" {
    let params: List[QueryParam] = parse_query_string("name=kira")
    let result: List[string] = get_query_params(params, "name")
    var is_valid: bool
    match result {
        Cons(v, Nil) => { is_valid = v == "kira" }
        _ => { is_valid = false }
    }
    assert(is_valid)
}

test "get_query_params returns empty for missing param" {
    let params: List[QueryParam] = parse_query_string("name=kira")
    let result: List[string] = get_query_params(params, "missing")
    var is_empty: bool
    match result {
        Nil => { is_empty = true }
        Cons(_, _) => { is_empty = false }
    }
    assert(is_empty)
}

// Path parameter extraction tests

test "extract_path_param extracts simple param" {
    let result: Option[string] = extract_path_param("/users/:id", "/users/123", "id")
    var is_valid: bool
    match result {
        Some(v) => { is_valid = v == "123" }
        None => { is_valid = false }
    }
    assert(is_valid)
}

test "extract_path_param extracts nested param" {
    let result: Option[string] = extract_path_param("/posts/:postId/comments/:commentId", "/posts/42/comments/7", "commentId")
    var is_valid: bool
    match result {
        Some(v) => { is_valid = v == "7" }
        None => { is_valid = false }
    }
    assert(is_valid)
}

test "extract_path_param extracts first of multiple params" {
    let result: Option[string] = extract_path_param("/posts/:postId/comments/:commentId", "/posts/42/comments/7", "postId")
    var is_valid: bool
    match result {
        Some(v) => { is_valid = v == "42" }
        None => { is_valid = false }
    }
    assert(is_valid)
}

test "extract_path_param returns None for wrong param name" {
    let result: Option[string] = extract_path_param("/users/:id", "/users/123", "userId")
    var is_not_found: bool
    match result {
        Some(_) => { is_not_found = false }
        None => { is_not_found = true }
    }
    assert(is_not_found)
}

test "extract_path_param returns None for path without params" {
    let result: Option[string] = extract_path_param("/users/list", "/users/list", "id")
    var is_not_found: bool
    match result {
        Some(_) => { is_not_found = false }
        None => { is_not_found = true }
    }
    assert(is_not_found)
}

// Path matching tests

test "path_matches exact path" {
    assert(path_matches("/users", "/users") == true)
}

test "path_matches path with param" {
    assert(path_matches("/users/:id", "/users/123") == true)
}

test "path_matches path with multiple params" {
    assert(path_matches("/posts/:postId/comments/:commentId", "/posts/42/comments/7") == true)
}

test "path_matches returns false for different length" {
    assert(path_matches("/users/:id", "/users/123/extra") == false)
}

test "path_matches returns false for different segment" {
    assert(path_matches("/users/:id", "/posts/123") == false)
}

test "path_matches root path" {
    assert(path_matches("/", "/") == true)
}

// Invalid URL handling tests

test "parse_url fails for empty string" {
    let result: Result[Url, HttpError] = parse_url("")
    var is_error: bool
    match result {
        Ok(_) => { is_error = false }
        Err(_) => { is_error = true }
    }
    assert(is_error)
}

test "parse_url fails for missing scheme" {
    let result: Result[Url, HttpError] = parse_url("example.com/path")
    var is_error: bool
    match result {
        Ok(_) => { is_error = false }
        Err(_) => { is_error = true }
    }
    assert(is_error)
}

test "parse_url fails for empty scheme" {
    let result: Result[Url, HttpError] = parse_url("://example.com")
    var is_error: bool
    match result {
        Ok(_) => { is_error = false }
        Err(_) => { is_error = true }
    }
    assert(is_error)
}

test "parse_url fails for missing host" {
    let result: Result[Url, HttpError] = parse_url("https:///path")
    var is_error: bool
    match result {
        Ok(_) => { is_error = false }
        Err(_) => { is_error = true }
    }
    assert(is_error)
}

test "parse_url fails for invalid port letters" {
    let result: Result[Url, HttpError] = parse_url("https://example.com:abc/path")
    var is_error: bool
    match result {
        Ok(_) => { is_error = false }
        Err(_) => { is_error = true }
    }
    assert(is_error)
}

test "parse_url fails for port out of range" {
    let result: Result[Url, HttpError] = parse_url("https://example.com:70000/path")
    var is_error: bool
    match result {
        Ok(_) => { is_error = false }
        Err(_) => { is_error = true }
    }
    assert(is_error)
}

test "parse_url fails for negative port" {
    let result: Result[Url, HttpError] = parse_url("https://example.com:-1/path")
    var is_error: bool
    match result {
        Ok(_) => { is_error = false }
        Err(_) => { is_error = true }
    }
    assert(is_error)
}
