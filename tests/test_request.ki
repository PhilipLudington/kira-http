/// Tests for kira-http request module
///
/// Tests request builder chaining, header accumulation, body setting, and build.

module http.tests.test_request

use http.types.Method
use http.types.Header
use http.types.Headers
use http.types.QueryParam
use http.request.Request
use http.request.RequestBuilder
use http.request.new_request
use http.request.with_header
use http.request.with_headers
use http.request.with_body
use http.request.with_json
use http.request.with_timeout
use http.request.build
use http.request.get_query_param
use http.request.get_query_params
use http.request.path_param
use http.request.with_path_params
use http.headers.get_header

// new_request tests

let test_new_request_sets_method: fn() -> void = fn() -> void {
    let builder: RequestBuilder = new_request(GET, "https://example.com")
    var matches: bool
    match builder.method {
        GET => { matches = true }
        _ => { matches = false }
    }
    assert(matches)
    return
}

let test_new_request_sets_url: fn() -> void = fn() -> void {
    let builder: RequestBuilder = new_request(GET, "https://example.com")
    assert(builder.url == "https://example.com")
    return
}

let test_new_request_empty_headers: fn() -> void = fn() -> void {
    let builder: RequestBuilder = new_request(GET, "https://example.com")
    var is_empty: bool
    match builder.headers {
        Nil => { is_empty = true }
        Cons(_, _) => { is_empty = false }
    }
    assert(is_empty)
    return
}

let test_new_request_no_body: fn() -> void = fn() -> void {
    let builder: RequestBuilder = new_request(GET, "https://example.com")
    var is_none: bool
    match builder.body {
        None => { is_none = true }
        Some(_) => { is_none = false }
    }
    assert(is_none)
    return
}

let test_new_request_no_timeout: fn() -> void = fn() -> void {
    let builder: RequestBuilder = new_request(GET, "https://example.com")
    var is_none: bool
    match builder.timeout {
        None => { is_none = true }
        Some(_) => { is_none = false }
    }
    assert(is_none)
    return
}

let test_new_request_post: fn() -> void = fn() -> void {
    let builder: RequestBuilder = new_request(POST, "https://example.com/api")
    var matches: bool
    match builder.method {
        POST => { matches = true }
        _ => { matches = false }
    }
    assert(matches)
    return
}

// with_header tests

let test_with_header_adds_header: fn() -> void = fn() -> void {
    let builder: RequestBuilder = new_request(GET, "https://example.com")
        |> with_header("Content-Type", "application/json")
    var found: bool
    match get_header(builder.headers, "Content-Type") {
        Some(v) => { found = v == "application/json" }
        None => { found = false }
    }
    assert(found)
    return
}

let test_with_header_chaining: fn() -> void = fn() -> void {
    let builder: RequestBuilder = new_request(GET, "https://example.com")
        |> with_header("Content-Type", "application/json")
        |> with_header("Accept", "text/html")

    var has_content_type: bool
    match get_header(builder.headers, "Content-Type") {
        Some(v) => { has_content_type = v == "application/json" }
        None => { has_content_type = false }
    }

    var has_accept: bool
    match get_header(builder.headers, "Accept") {
        Some(v) => { has_accept = v == "text/html" }
        None => { has_accept = false }
    }

    assert(has_content_type and has_accept)
    return
}

let test_with_header_replaces_existing: fn() -> void = fn() -> void {
    let builder: RequestBuilder = new_request(GET, "https://example.com")
        |> with_header("Content-Type", "text/plain")
        |> with_header("Content-Type", "application/json")

    var found: bool
    match get_header(builder.headers, "Content-Type") {
        Some(v) => { found = v == "application/json" }
        None => { found = false }
    }
    assert(found)
    return
}

// with_headers tests

let test_with_headers_adds_multiple: fn() -> void = fn() -> void {
    let headers: Headers = Cons(
        Header { name: "Content-Type", value: "application/json" },
        Cons(
            Header { name: "Accept", value: "text/html" },
            Nil
        )
    )
    let builder: RequestBuilder = new_request(GET, "https://example.com")
        |> with_headers(headers)

    var has_content_type: bool
    match get_header(builder.headers, "Content-Type") {
        Some(v) => { has_content_type = v == "application/json" }
        None => { has_content_type = false }
    }

    var has_accept: bool
    match get_header(builder.headers, "Accept") {
        Some(v) => { has_accept = v == "text/html" }
        None => { has_accept = false }
    }

    assert(has_content_type and has_accept)
    return
}

let test_with_headers_empty_list: fn() -> void = fn() -> void {
    let builder: RequestBuilder = new_request(GET, "https://example.com")
        |> with_header("Existing", "value")
        |> with_headers(Nil)

    var found: bool
    match get_header(builder.headers, "Existing") {
        Some(v) => { found = v == "value" }
        None => { found = false }
    }
    assert(found)
    return
}

// with_body tests

let test_with_body_sets_body: fn() -> void = fn() -> void {
    let builder: RequestBuilder = new_request(POST, "https://example.com")
        |> with_body("request body")

    var has_body: bool
    match builder.body {
        Some(b) => { has_body = b == "request body" }
        None => { has_body = false }
    }
    assert(has_body)
    return
}

let test_with_body_replaces_existing: fn() -> void = fn() -> void {
    let builder: RequestBuilder = new_request(POST, "https://example.com")
        |> with_body("first body")
        |> with_body("second body")

    var has_body: bool
    match builder.body {
        Some(b) => { has_body = b == "second body" }
        None => { has_body = false }
    }
    assert(has_body)
    return
}

