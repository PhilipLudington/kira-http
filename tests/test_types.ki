    return
}

let test_is_client_error_ok_false: fn() -> void = fn() -> void {
    assert(is_client_error(OK) == false)
    return
}

let test_is_client_error_internal_error_false: fn() -> void = fn() -> void {
    assert(is_client_error(InternalError) == false)
