/// Tests for kira-http core types
///
/// Tests status code conversion, status category checks, and header manipulation.

module http.tests.test_types

import http.types.{Status, Header, Headers}
import http.status.{status_code, status_from_code, is_success, is_redirect, is_client_error, is_server_error}
import http.headers.{get_header, set_header, remove_header, content_type, authorization, accept}

// Status code conversion tests

let test_status_code_ok: fn() -> void = fn() -> void {
    assert(status_code(OK) == 200)
    return
}

let test_status_code_created: fn() -> void = fn() -> void {
    assert(status_code(Created) == 201)
    return
}

let test_status_code_accepted: fn() -> void = fn() -> void {
    assert(status_code(Accepted) == 202)
    return
}

let test_status_code_no_content: fn() -> void = fn() -> void {
    assert(status_code(NoContent) == 204)
    return
}

let test_status_code_moved_permanently: fn() -> void = fn() -> void {
    assert(status_code(MovedPermanently) == 301)
    return
}

let test_status_code_found: fn() -> void = fn() -> void {
    assert(status_code(Found) == 302)
    return
}

let test_status_code_not_modified: fn() -> void = fn() -> void {
    assert(status_code(NotModified) == 304)
    return
}

let test_status_code_bad_request: fn() -> void = fn() -> void {
    assert(status_code(BadRequest) == 400)
    return
}

let test_status_code_unauthorized: fn() -> void = fn() -> void {
    assert(status_code(Unauthorized) == 401)
    return
}

let test_status_code_forbidden: fn() -> void = fn() -> void {
    assert(status_code(Forbidden) == 403)
    return
}

let test_status_code_not_found: fn() -> void = fn() -> void {
    assert(status_code(NotFound) == 404)
    return
}

let test_status_code_method_not_allowed: fn() -> void = fn() -> void {
    assert(status_code(MethodNotAllowed) == 405)
    return
}

let test_status_code_conflict: fn() -> void = fn() -> void {
    assert(status_code(Conflict) == 409)
    return
}

let test_status_code_internal_error: fn() -> void = fn() -> void {
    assert(status_code(InternalError) == 500)
    return
}

let test_status_code_not_implemented: fn() -> void = fn() -> void {
    assert(status_code(NotImplemented) == 501)
    return
}

let test_status_code_bad_gateway: fn() -> void = fn() -> void {
    assert(status_code(BadGateway) == 502)
    return
}

let test_status_code_service_unavailable: fn() -> void = fn() -> void {
    assert(status_code(ServiceUnavailable) == 503)
    return
}

let test_status_code_custom: fn() -> void = fn() -> void {
    assert(status_code(Custom(418)) == 418)
    return
}

// Status from code conversion tests

let test_status_from_code_200: fn() -> void = fn() -> void {
    var matches: bool
    match status_from_code(200) {
        OK => { matches = true }
        _ => { matches = false }
    }
    assert(matches)
    return
}

let test_status_from_code_404: fn() -> void = fn() -> void {
    var matches: bool
    match status_from_code(404) {
        NotFound => { matches = true }
        _ => { matches = false }
    }
    assert(matches)
    return
}

let test_status_from_code_500: fn() -> void = fn() -> void {
    var matches: bool
    match status_from_code(500) {
        InternalError => { matches = true }
        _ => { matches = false }
    }
    assert(matches)
    return
}

let test_status_from_code_unknown: fn() -> void = fn() -> void {
    var matches: bool
    match status_from_code(418) {
        Custom(418) => { matches = true }
        _ => { matches = false }
    }
    assert(matches)
    return
}

// Round-trip tests

let test_status_code_roundtrip_ok: fn() -> void = fn() -> void {
    let code: i32 = status_code(OK)
    var matches: bool
    match status_from_code(code) {
        OK => { matches = true }
        _ => { matches = false }
    }
    assert(matches)
    return
}

let test_status_code_roundtrip_not_found: fn() -> void = fn() -> void {
    let code: i32 = status_code(NotFound)
    var matches: bool
    match status_from_code(code) {
        NotFound => { matches = true }
        _ => { matches = false }
    }
    assert(matches)
    return
}

let test_status_code_roundtrip_custom: fn() -> void = fn() -> void {
    let code: i32 = status_code(Custom(418))
    var matches: bool
    match status_from_code(code) {
        Custom(418) => { matches = true }
        _ => { matches = false }
    }
    assert(matches)
    return
}

