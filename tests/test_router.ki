/// Tests for kira-http router module
///
/// Tests route matching, path parameter extraction, and request handling.
/// Self-contained for Kira v0.1.0 (no module system support).

// ============================================================================
// Type Definitions
// ============================================================================

type Method =
    | GET
    | POST
    | PUT
    | DELETE
    | PATCH
    | HEAD
    | OPTIONS

type Status =
    | OK
    | NotFound

type Header = {
    name: string,
    value: string
}

type Headers = List[Header]

type QueryParam = {
    key: string,
    value: string
}

type Request = {
    method: Method,
    url: string,
    path: string,
    headers: Headers,
    body: Option[string],
    query: List[QueryParam],
    path_params: List[QueryParam]
}

type Response = {
    status: Status,
    headers: Headers,
    body: string
}

type Handler = fn(Request) -> Response

type Route = {
    method: Method,
    path: string,
    handler: Handler
}

type Router = {
    routes: List[Route],
    not_found: Option[Handler]
}

// ============================================================================
// Helper Functions
// ============================================================================

let split_path: fn(string) -> List[string] =
    fn(path: string) -> List[string] {
        var working_path: string
        if std.string.length(path) > 0 and std.string.char_at(path, 0) == '/' {
            working_path = std.string.substring(path, 1, std.string.length(path))
        } else {
            working_path = path
        }

        if std.string.length(working_path) == 0 {
            return Nil
        }

        return split_by_slash(working_path)
    }

let split_by_slash: fn(string) -> List[string] =
    fn(s: string) -> List[string] {
        let slash_idx: Option[i32] = std.string.index_of(s, "/")

        match slash_idx {
            Some(idx) => {
                let segment: string = std.string.substring(s, 0, idx)
                let rest: string = std.string.substring(s, idx + 1, std.string.length(s))
                if std.string.length(rest) > 0 {
                    if std.string.length(segment) > 0 {
                        return Cons(segment, split_by_slash(rest))
                    } else {
                        return split_by_slash(rest)
                    }
                } else {
                    if std.string.length(segment) > 0 {
                        return Cons(segment, Nil)
                    } else {
                        return Nil
                    }
                }
            }
            None => {
                if std.string.length(s) > 0 {
                    return Cons(s, Nil)
                } else {
                    return Nil
                }
            }
        }
    }

let methods_match: fn(Method, Method) -> bool =
    fn(a: Method, b: Method) -> bool {
        var result: bool
        match a {
            GET => {
                match b { GET => { result = true } _ => { result = false } }
            }
            POST => {
                match b { POST => { result = true } _ => { result = false } }
            }
            PUT => {
                match b { PUT => { result = true } _ => { result = false } }
            }
            DELETE => {
                match b { DELETE => { result = true } _ => { result = false } }
            }
            PATCH => {
                match b { PATCH => { result = true } _ => { result = false } }
            }
            HEAD => {
                match b { HEAD => { result = true } _ => { result = false } }
            }
            OPTIONS => {
                match b { OPTIONS => { result = true } _ => { result = false } }
            }
        }
        return result
    }

let paths_match: fn(string, string) -> bool =
    fn(pattern: string, path: string) -> bool {
        let pattern_segments: List[string] = split_path(pattern)
        let path_segments: List[string] = split_path(path)
        return segments_match(pattern_segments, path_segments)
    }

let segments_match: fn(List[string], List[string]) -> bool =
    fn(pattern_segments: List[string], path_segments: List[string]) -> bool {
        var result: bool
        match pattern_segments {
            Nil => {
                match path_segments {
                    Nil => { result = true }
                    Cons(_, _) => { result = false }
                }
            }
            Cons(pattern_seg, pattern_rest) => {
                match path_segments {
                    Nil => { result = false }
                    Cons(path_seg, path_rest) => {
                        if std.string.length(pattern_seg) > 0 and std.string.substring(pattern_seg, 0, 1) == ":" {
                            result = segments_match(pattern_rest, path_rest)
                        } else if pattern_seg == path_seg {
                            result = segments_match(pattern_rest, path_rest)
                        } else {
                            result = false
                        }
                    }
                }
            }
        }
        return result
    }

// ============================================================================
// Router Functions
// ============================================================================

let new_router: fn() -> Router = fn() -> Router {
    return Router {
        routes: Nil,
        not_found: None
    }
}

let route_count: fn(Router) -> i32 = fn(router: Router) -> i32 {
    return list_length(router.routes)
}

let list_length: fn(List[Route]) -> i32 = fn(list: List[Route]) -> i32 {
    var count: i32
    match list {
        Nil => { count = 0 }
        Cons(_, rest) => { count = 1 + list_length(rest) }
    }
    return count
}

let add_route: fn(Router, Route) -> Router =
    fn(router: Router, new_route: Route) -> Router {
        return Router {
            routes: Cons(new_route, router.routes),
            not_found: router.not_found
        }
    }

let get: fn(string, Handler) -> Route = fn(path: string, handler: Handler) -> Route {
    return Route { method: GET, path: path, handler: handler }
}

let post: fn(string, Handler) -> Route = fn(path: string, handler: Handler) -> Route {
    return Route { method: POST, path: path, handler: handler }
}

let put: fn(string, Handler) -> Route = fn(path: string, handler: Handler) -> Route {
    return Route { method: PUT, path: path, handler: handler }
}

let delete_route: fn(string, Handler) -> Route = fn(path: string, handler: Handler) -> Route {
    return Route { method: DELETE, path: path, handler: handler }
}

let get_method: fn(Route) -> Method = fn(route: Route) -> Method {
    return route.method
}

let get_path: fn(Route) -> string = fn(route: Route) -> string {
    return route.path
}

// ============================================================================
// Tests: Router creation
// ============================================================================

test "new_router creates empty router" {
    let router: Router = new_router()
    assert(route_count(router) == 0)
}

test "add_route adds single route" {
    let handler: Handler = fn(req: Request) -> Response {
        return Response { status: OK, headers: Nil, body: "test" }
    }
    let router: Router = add_route(new_router(), get("/", handler))
    assert(route_count(router) == 1)
}

test "add_route adds multiple routes" {
    let handler: Handler = fn(req: Request) -> Response {
        return Response { status: OK, headers: Nil, body: "test" }
    }
    let r1: Router = add_route(new_router(), get("/", handler))
    let r2: Router = add_route(r1, get("/users", handler))
    let router: Router = add_route(r2, post("/users", handler))
    assert(route_count(router) == 3)
}

// ============================================================================
// Tests: Route helpers
// ============================================================================

test "get helper creates GET route" {
    let handler: Handler = fn(req: Request) -> Response {
        return Response { status: OK, headers: Nil, body: "test" }
    }
    let route: Route = get("/users", handler)
    assert(methods_match(get_method(route), GET))
    assert(get_path(route) == "/users")
}

test "post helper creates POST route" {
    let handler: Handler = fn(req: Request) -> Response {
        return Response { status: OK, headers: Nil, body: "test" }
    }
    let route: Route = post("/users", handler)
    assert(methods_match(get_method(route), POST))
}

test "put helper creates PUT route" {
    let handler: Handler = fn(req: Request) -> Response {
        return Response { status: OK, headers: Nil, body: "test" }
    }
    let route: Route = put("/users/:id", handler)
    assert(methods_match(get_method(route), PUT))
}

test "delete helper creates DELETE route" {
    let handler: Handler = fn(req: Request) -> Response {
        return Response { status: OK, headers: Nil, body: "test" }
    }
    let route: Route = delete_route("/users/:id", handler)
    assert(methods_match(get_method(route), DELETE))
}

// ============================================================================
// Tests: Path matching
// ============================================================================

test "paths_match exact path" {
    assert(paths_match("/users", "/users") == true)
}

test "paths_match root path" {
    assert(paths_match("/", "/") == true)
}

test "paths_match nested path" {
    assert(paths_match("/api/v1/users", "/api/v1/users") == true)
}

test "paths_match different paths" {
    assert(paths_match("/users", "/posts") == false)
}

test "paths_match different length" {
    assert(paths_match("/users", "/users/123") == false)
}

test "paths_match with param" {
    assert(paths_match("/users/:id", "/users/123") == true)
}

test "paths_match with multiple params" {
    assert(paths_match("/posts/:postId/comments/:commentId", "/posts/42/comments/7") == true)
}

test "paths_match with param different length" {
    assert(paths_match("/users/:id", "/users/123/extra") == false)
}

// ============================================================================
// Tests: Method matching
// ============================================================================

test "methods_match GET" {
    assert(methods_match(GET, GET) == true)
}

test "methods_match POST" {
    assert(methods_match(POST, POST) == true)
}

test "methods_match different" {
    assert(methods_match(GET, POST) == false)
}

test "methods_match PUT" {
    assert(methods_match(PUT, PUT) == true)
}

test "methods_match DELETE" {
    assert(methods_match(DELETE, DELETE) == true)
}

// ============================================================================
// Tests: Path splitting
// ============================================================================

test "split_path empty" {
    let segments: List[string] = split_path("")
    var is_empty: bool
    match segments {
        Nil => { is_empty = true }
        Cons(_, _) => { is_empty = false }
    }
    assert(is_empty)
}

test "split_path root" {
    let segments: List[string] = split_path("/")
    var is_empty: bool
    match segments {
        Nil => { is_empty = true }
        Cons(_, _) => { is_empty = false }
    }
    assert(is_empty)
}

test "split_path single segment" {
    let segments: List[string] = split_path("/users")
    var is_valid: bool
    match segments {
        Cons(seg, Nil) => { is_valid = seg == "users" }
        _ => { is_valid = false }
    }
    assert(is_valid)
}

test "split_path two segments" {
    let segments: List[string] = split_path("/users/123")
    var is_valid: bool
    match segments {
        Cons(seg1, Cons(seg2, Nil)) => {
            is_valid = seg1 == "users" and seg2 == "123"
        }
        _ => { is_valid = false }
    }
    assert(is_valid)
}
