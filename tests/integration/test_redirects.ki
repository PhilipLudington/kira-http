// ============================================================================
// Tests: 301/302 changes method to GET
// ============================================================================

test "301 redirect changes POST to GET" {
    let req: Request = make_request(
        POST,
        "https://httpbin.org/redirect-to?url=https://httpbin.org/get&status_code=301",
        "/redirect-to",
        Nil,
        Some("test body")
    )
    let result: Result[Response, HttpError] = request(req)
    match result {
        Ok(response) => {
            assert(status_code(response.status) == 200, "Expected 200 — POST should change to GET on 301")
        }
        Err(_) => {
            assert(false, "Request should succeed")
        }
    }
}

test "302 redirect changes POST to GET" {
    let req: Request = make_request(
        POST,
        "https://httpbin.org/redirect-to?url=https://httpbin.org/get&status_code=302",
        "/redirect-to",
        Nil,
        Some("test body")
    )
    let result: Result[Response, HttpError] = request(req)
    match result {
        Ok(response) => {
            assert(status_code(response.status) == 200, "Expected 200 — POST should change to GET on 302")
        }
        Err(_) => {
            assert(false, "Request should succeed")
        }
    }
}

// ============================================================================
// Tests: 307/308 preserves method and body
// ============================================================================

test "307 redirect preserves POST method and body" {
    let ct: Header = Header { name: "Content-Type", value: "application/json" }
    let req: Request = make_request(
        POST,
        "https://httpbin.org/redirect-to?url=https://httpbin.org/post&status_code=307",
        "/redirect-to",
        Cons(ct, Nil),
        Some("{\"key\": \"value\"}")
    )
    let result: Result[Response, HttpError] = request(req)
    match result {
        Ok(response) => {
            assert(status_code(response.status) == 200, "Expected 200 — POST should be preserved on 307")
            let has_body: bool = std.string.contains(response.body, "key")
            assert(has_body, "Response should contain the forwarded body")
        }
        Err(_) => {
            assert(false, "Request should succeed")
        }
    }
}

test "308 redirect preserves POST method and body" {
    let ct: Header = Header { name: "Content-Type", value: "application/json" }
    let req: Request = make_request(
        POST,
        "https://httpbin.org/redirect-to?url=https://httpbin.org/post&status_code=308",
        "/redirect-to",
        Cons(ct, Nil),
        Some("{\"preserved\": true}")
    )
    let result: Result[Response, HttpError] = request(req)
    match result {
        Ok(response) => {
            assert(status_code(response.status) == 200, "Expected 200 — POST should be preserved on 308")
            let has_body: bool = std.string.contains(response.body, "preserved")
            assert(has_body, "Response should contain the forwarded body")
        }
        Err(_) => {
            assert(false, "Request should succeed")
        }
    }
}
