// ============================================================================
// Tests: json_response
// ============================================================================

test "json_response sets status" {
    let response: Response = json_response(OK, "{}")
    var matches: bool
    match response.status {
        OK => { matches = true }
        _ => { matches = false }
    }
    assert(matches)
}

test "json_response sets body" {
    let response: Response = json_response(OK, "{\"name\": \"Alice\"}")
    assert(response.body == "{\"name\": \"Alice\"}")
}

test "json_response sets content type" {
    let response: Response = json_response(OK, "{}")
    var has_json_type: bool
    match get_header(response.headers, "Content-Type") {
        Some(v) => { has_json_type = v == "application/json" }
        None => { has_json_type = false }
    }
    assert(has_json_type)
}

test "json_response works with error status" {
    let response: Response = json_response(BadRequest, "{\"error\": \"bad\"}")
    var matches: bool
    match response.status {
        BadRequest => { matches = true }
        _ => { matches = false }
    }
    assert(matches)
}

