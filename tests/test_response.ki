// ============================================================================
// Tests: redirect
// ============================================================================

test "redirect sets Found status" {
    let response: Response = redirect("https://example.com")
    var matches: bool
    match response.status {
        Found => { matches = true }
        _ => { matches = false }
    }
    assert(matches)
}

test "redirect sets Location header" {
    let response: Response = redirect("https://example.com/new")
    var has_location: bool
    match get_header(response.headers, "Location") {
        Some(v) => { has_location = v == "https://example.com/new" }
        None => { has_location = false }
    }
    assert(has_location)
}

test "redirect has empty body" {
    let response: Response = redirect("https://example.com")
    assert(response.body == "")
}

test "redirect returns 302 status code" {
    let response: Response = redirect("https://example.com")
    assert(status_code(response.status) == 302)
}

