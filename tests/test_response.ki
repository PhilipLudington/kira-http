/// Tests for kira-http response module
///
/// Tests response helper functions and correct status codes and headers.
/// Self-contained for Kira v0.1.0 (no module system support).

// ============================================================================
// Type Definitions
// ============================================================================

type Status =
    | OK
    | Created
    | Accepted
    | NoContent
    | MovedPermanently
    | Found
    | NotModified
    | BadRequest
    | Unauthorized
    | Forbidden
    | NotFound
    | MethodNotAllowed
    | Conflict
    | InternalError
    | NotImplemented
    | BadGateway
    | ServiceUnavailable
    | Custom(i32)

type Header = {
    name: string,
    value: string
}

type Headers = List[Header]

type Response = {
    status: Status,
    headers: Headers,
    body: string
}

// ============================================================================
// Helper Functions
// ============================================================================

let make_json_content_type: fn() -> Header = fn() -> Header {
    return Header { name: "Content-Type", value: "application/json" }
}

let make_text_content_type: fn() -> Header = fn() -> Header {
    return Header { name: "Content-Type", value: "text/plain" }
}

let get_header: fn(Headers, string) -> Option[string] =
    fn(headers: Headers, name: string) -> Option[string] {
        let lower_name: string = std.string.to_lower(name)
        return find_header_value(headers, lower_name)
    }

let find_header_value: fn(Headers, string) -> Option[string] =
    fn(headers: Headers, lower_name: string) -> Option[string] {
        var result: Option[string]
        match headers {
            Nil => { result = None }
            Cons(header, rest) => {
                let header_lower: string = std.string.to_lower(header.name)
                if header_lower == lower_name {
                    result = Some(header.value)
                } else {
                    result = find_header_value(rest, lower_name)
                }
            }
        }
        return result
    }

let status_code: fn(Status) -> i32 = fn(status: Status) -> i32 {
    var code: i32
    match status {
        OK => { code = 200 }
        Created => { code = 201 }
        Accepted => { code = 202 }
        NoContent => { code = 204 }
        MovedPermanently => { code = 301 }
        Found => { code = 302 }
        NotModified => { code = 304 }
        BadRequest => { code = 400 }
        Unauthorized => { code = 401 }
        Forbidden => { code = 403 }
        NotFound => { code = 404 }
        MethodNotAllowed => { code = 405 }
        Conflict => { code = 409 }
        InternalError => { code = 500 }
        NotImplemented => { code = 501 }
        BadGateway => { code = 502 }
        ServiceUnavailable => { code = 503 }
        Custom(n) => { code = n }
    }
    return code
}

// ============================================================================
// Response Functions
// ============================================================================

let ok: fn(string) -> Response = fn(body: string) -> Response {
    return Response {
        status: OK,
        headers: Cons(make_text_content_type(), Nil),
        body: body
    }
}

let created: fn(string) -> Response = fn(body: string) -> Response {
    return Response {
        status: Created,
        headers: Cons(make_text_content_type(), Nil),
        body: body
    }
}

let no_content: fn() -> Response = fn() -> Response {
    return Response {
        status: NoContent,
        headers: Nil,
        body: ""
    }
}

let bad_request: fn(string) -> Response = fn(message: string) -> Response {
    return Response {
        status: BadRequest,
        headers: Cons(make_text_content_type(), Nil),
        body: message
    }
}

let unauthorized: fn(string) -> Response = fn(message: string) -> Response {
    return Response {
        status: Unauthorized,
        headers: Cons(make_text_content_type(), Nil),
        body: message
    }
}

let forbidden: fn(string) -> Response = fn(message: string) -> Response {
    return Response {
        status: Forbidden,
        headers: Cons(make_text_content_type(), Nil),
        body: message
    }
}

let not_found: fn() -> Response = fn() -> Response {
    return Response {
        status: NotFound,
        headers: Cons(make_text_content_type(), Nil),
        body: "Not Found"
    }
}

let method_not_allowed: fn() -> Response = fn() -> Response {
    return Response {
        status: MethodNotAllowed,
        headers: Cons(make_text_content_type(), Nil),
        body: "Method Not Allowed"
    }
}

let conflict: fn(string) -> Response = fn(message: string) -> Response {
    return Response {
        status: Conflict,
        headers: Cons(make_text_content_type(), Nil),
        body: message
    }
}

let internal_error: fn(string) -> Response = fn(message: string) -> Response {
    return Response {
        status: InternalError,
        headers: Cons(make_text_content_type(), Nil),
        body: message
    }
}

let service_unavailable: fn(string) -> Response = fn(message: string) -> Response {
    return Response {
        status: ServiceUnavailable,
        headers: Cons(make_text_content_type(), Nil),
        body: message
    }
}

let json_response: fn(Status, string) -> Response =
    fn(status: Status, json_body: string) -> Response {
        return Response {
            status: status,
            headers: Cons(make_json_content_type(), Nil),
            body: json_body
        }
    }

let json_ok: fn(string) -> Response = fn(json_body: string) -> Response {
    return json_response(OK, json_body)
}

let json_created: fn(string) -> Response = fn(json_body: string) -> Response {
    return json_response(Created, json_body)
}

let redirect: fn(string) -> Response = fn(location: string) -> Response {
    let location_header: Header = Header { name: "Location", value: location }
    return Response {
        status: Found,
        headers: Cons(location_header, Nil),
        body: ""
    }
}

let permanent_redirect: fn(string) -> Response = fn(location: string) -> Response {
    let location_header: Header = Header { name: "Location", value: location }
    return Response {
        status: MovedPermanently,
        headers: Cons(location_header, Nil),
        body: ""
    }
}

let with_header: fn(Response, string, string) -> Response =
    fn(response: Response, name: string, value: string) -> Response {
        let new_header: Header = Header { name: name, value: value }
        return Response {
            status: response.status,
            headers: Cons(new_header, response.headers),
            body: response.body
        }
    }

let with_body: fn(Response, string) -> Response =
    fn(response: Response, body: string) -> Response {
        return Response {
            status: response.status,
            headers: response.headers,
            body: body
        }
    }

let with_status: fn(Response, Status) -> Response =
    fn(response: Response, status: Status) -> Response {
        return Response {
            status: status,
            headers: response.headers,
            body: response.body
        }
    }

// ============================================================================
// Tests: ok
// ============================================================================

test "ok sets OK status" {
    let response: Response = ok("Hello")
    var matches: bool
    match response.status {
        OK => { matches = true }
        _ => { matches = false }
    }
    assert(matches)
}

test "ok sets body" {
    let response: Response = ok("Hello, World!")
    assert(response.body == "Hello, World!")
}

test "ok sets content type" {
    let response: Response = ok("Hello")
    var has_content_type: bool
    match get_header(response.headers, "Content-Type") {
        Some(v) => { has_content_type = v == "text/plain" }
        None => { has_content_type = false }
    }
    assert(has_content_type)
}

