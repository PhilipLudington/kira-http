// no_content tests

let test_no_content_status: fn() -> void = fn() -> void {
    let response: Response = no_content()
    var matches: bool
    match response.status {
        NoContent => { matches = true }
        _ => { matches = false }
    }
    assert(matches)
    return
}

let test_no_content_empty_body: fn() -> void = fn() -> void {
    let response: Response = no_content()
    assert(response.body == "")
    return
}

let test_no_content_no_headers: fn() -> void = fn() -> void {
    let response: Response = no_content()
    var is_empty: bool
    match response.headers {
        Nil => { is_empty = true }
        Cons(_, _) => { is_empty = false }
    }
    assert(is_empty)
    return
}

