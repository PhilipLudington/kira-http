test "parse_url extracts query string" {
    let result: Result[Url, HttpError] = parse_url("https://example.com/search?q=kira")
    var is_valid: bool
    match result {
        Ok(url) => {
            match url.query {
                Some(q) => { is_valid = q == "q=kira" }
                None => { is_valid = false }
            }
        }
        Err(_) => { is_valid = false }
    }
    assert(is_valid)
}

test "parse_url extracts multiple query params" {
    let result: Result[Url, HttpError] = parse_url("https://example.com/search?q=kira&limit=10")
    var is_valid: bool
    match result {
        Ok(url) => {
            match url.query {
                Some(q) => { is_valid = q == "q=kira&limit=10" }
                None => { is_valid = false }
            }
        }
        Err(_) => { is_valid = false }
    }
    assert(is_valid)
}

test "parse_url has None query when not specified" {
    let result: Result[Url, HttpError] = parse_url("https://example.com/path")
    var is_valid: bool
    match result {
        Ok(url) => {
            match url.query {
                Some(_) => { is_valid = false }
                None => { is_valid = true }
            }
        }
        Err(_) => { is_valid = false }
    }
    assert(is_valid)
}

