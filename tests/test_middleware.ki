/// Tests for kira-http middleware module
///
/// Tests middleware types and basic composition.
/// Self-contained for Kira v0.1.0 (no module system support).

// ============================================================================
// Type Definitions
// ============================================================================

type Method =
    | GET
    | POST

type Status =
    | OK

type Header = {
    name: string,
    value: string
}

type Headers = List[Header]

type Request = {
    method: Method,
    url: string,
    path: string,
    headers: Headers,
    body: Option[string]
}

type Response = {
    status: Status,
    headers: Headers,
    body: string
}

// Note: Handler and Middleware are NOT defined as type aliases because
// Kira treats type aliases as nominal types that cannot be called.
// Use fn(Request) -> Response directly for handlers,
// and fn(fn(Request) -> Response) -> fn(Request) -> Response for middleware.

// ============================================================================
// Helper Functions
// ============================================================================

let make_request: fn(string) -> Request = fn(path: string) -> Request {
    return Request {
        method: GET,
        url: "http://localhost" + path,
        path: path,
        headers: Nil,
        body: None
    }
}

let ok: fn(string) -> Response = fn(body: string) -> Response {
    return Response { status: OK, headers: Nil, body: body }
}

let get_header: fn(Headers, string) -> Option[string] =
    fn(headers: Headers, name: string) -> Option[string] {
        var result: Option[string]
        match headers {
            Nil => { result = None }
            Cons(header, rest) => {
                if header.name == name {
                    result = Some(header.value)
                } else {
                    result = get_header(rest, name)
                }
            }
        }
        return result
    }

// ============================================================================
// Basic Middleware
// ============================================================================

let add_header_middleware: fn(string, string) -> fn(fn(Request) -> Response) -> fn(Request) -> Response =
    fn(name: string, value: string) -> fn(fn(Request) -> Response) -> fn(Request) -> Response {
        return fn(next: fn(Request) -> Response) -> fn(Request) -> Response {
            return fn(req: Request) -> Response {
                let response: Response = next(req)
                let new_header: Header = Header { name: name, value: value }
                return Response {
                    status: response.status,
                    headers: Cons(new_header, response.headers),
                    body: response.body
                }
            }
        }
    }

let identity_middleware: fn() -> fn(fn(Request) -> Response) -> fn(Request) -> Response =
    fn() -> fn(fn(Request) -> Response) -> fn(Request) -> Response {
        return fn(next: fn(Request) -> Response) -> fn(Request) -> Response {
            return next
        }
    }

let apply_middleware: fn(fn(Request) -> Response, fn(fn(Request) -> Response) -> fn(Request) -> Response) -> fn(Request) -> Response =
    fn(handler: fn(Request) -> Response, mw: fn(fn(Request) -> Response) -> fn(Request) -> Response) -> fn(Request) -> Response {
        return mw(handler)
    }

let compose: fn(fn(fn(Request) -> Response) -> fn(Request) -> Response, fn(fn(Request) -> Response) -> fn(Request) -> Response) -> fn(fn(Request) -> Response) -> fn(Request) -> Response =
    fn(first: fn(fn(Request) -> Response) -> fn(Request) -> Response, second: fn(fn(Request) -> Response) -> fn(Request) -> Response) -> fn(fn(Request) -> Response) -> fn(Request) -> Response {
        return fn(handler: fn(Request) -> Response) -> fn(Request) -> Response {
            return first(second(handler))
        }
    }

// ============================================================================
// Tests: Middleware types
// ============================================================================

test "middleware type is function" {
    let handler: fn(Request) -> Response = fn(req: Request) -> Response {
        return ok("test")
    }
    let mw: fn(fn(Request) -> Response) -> fn(Request) -> Response = identity_middleware()
    let wrapped: fn(Request) -> Response = mw(handler)
    let req: Request = make_request("/")
    let resp: Response = wrapped(req)
    assert(resp.body == "test")
}

test "identity middleware passes through" {
    let handler: fn(Request) -> Response = fn(req: Request) -> Response {
        return ok("hello")
    }
    let mw: fn(fn(Request) -> Response) -> fn(Request) -> Response = identity_middleware()
    let wrapped: fn(Request) -> Response = apply_middleware(handler, mw)
    let req: Request = make_request("/")
    let resp: Response = wrapped(req)
    assert(resp.body == "hello")
}

test "add_header_middleware adds header" {
    let handler: fn(Request) -> Response = fn(req: Request) -> Response {
        return ok("test")
    }
    let mw: fn(fn(Request) -> Response) -> fn(Request) -> Response = add_header_middleware("X-Custom", "value")
    let wrapped: fn(Request) -> Response = apply_middleware(handler, mw)
    let req: Request = make_request("/")
    let resp: Response = wrapped(req)

    var found: bool
    match get_header(resp.headers, "X-Custom") {
        Some(v) => { found = v == "value" }
        None => { found = false }
    }
    assert(found)
}

test "middleware preserves body" {
    let handler: fn(Request) -> Response = fn(req: Request) -> Response {
        return ok("original body")
    }
    let mw: fn(fn(Request) -> Response) -> fn(Request) -> Response = add_header_middleware("X-Test", "test")
    let wrapped: fn(Request) -> Response = apply_middleware(handler, mw)
    let req: Request = make_request("/")
    let resp: Response = wrapped(req)
    assert(resp.body == "original body")
}

test "middleware can read request" {
    let handler: fn(Request) -> Response = fn(req: Request) -> Response {
        return ok(req.path)
    }
    let mw: fn(fn(Request) -> Response) -> fn(Request) -> Response = identity_middleware()
    let wrapped: fn(Request) -> Response = apply_middleware(handler, mw)
    let req: Request = make_request("/api/users")
    let resp: Response = wrapped(req)
    assert(resp.body == "/api/users")
}

// ============================================================================
// Tests: Middleware composition
// ============================================================================

test "compose two middleware" {
    let handler: fn(Request) -> Response = fn(req: Request) -> Response {
        return ok("test")
    }
    let mw1: fn(fn(Request) -> Response) -> fn(Request) -> Response = add_header_middleware("X-First", "1")
    let mw2: fn(fn(Request) -> Response) -> fn(Request) -> Response = add_header_middleware("X-Second", "2")
    let combined: fn(fn(Request) -> Response) -> fn(Request) -> Response = compose(mw1, mw2)
    let wrapped: fn(Request) -> Response = combined(handler)
    let req: Request = make_request("/")
    let resp: Response = wrapped(req)

    var has_first: bool
    match get_header(resp.headers, "X-First") {
        Some(_) => { has_first = true }
        None => { has_first = false }
    }

    var has_second: bool
    match get_header(resp.headers, "X-Second") {
        Some(_) => { has_second = true }
        None => { has_second = false }
    }

    assert(has_first and has_second)
}

test "compose with identity" {
    let handler: fn(Request) -> Response = fn(req: Request) -> Response {
        return ok("test")
    }
    let mw: fn(fn(Request) -> Response) -> fn(Request) -> Response = add_header_middleware("X-Only", "value")
    let id: fn(fn(Request) -> Response) -> fn(Request) -> Response = identity_middleware()
    let combined: fn(fn(Request) -> Response) -> fn(Request) -> Response = compose(mw, id)
    let wrapped: fn(Request) -> Response = combined(handler)
    let req: Request = make_request("/")
    let resp: Response = wrapped(req)

    var found: bool
    match get_header(resp.headers, "X-Only") {
        Some(v) => { found = v == "value" }
        None => { found = false }
    }
    assert(found)
}

test "apply_middleware applies single" {
    let handler: fn(Request) -> Response = fn(req: Request) -> Response {
        return ok("base")
    }
    let mw: fn(fn(Request) -> Response) -> fn(Request) -> Response = add_header_middleware("X-Applied", "yes")
    let wrapped: fn(Request) -> Response = apply_middleware(handler, mw)
    let req: Request = make_request("/")
    let resp: Response = wrapped(req)

    var found: bool
    match get_header(resp.headers, "X-Applied") {
        Some(v) => { found = v == "yes" }
        None => { found = false }
    }
    assert(found)
}

// ============================================================================
// Tests: Middleware execution order
// ============================================================================

test "outer middleware executes first" {
    let handler: fn(Request) -> Response = fn(req: Request) -> Response {
        return ok("handler")
    }

    let first_mw: fn(fn(Request) -> Response) -> fn(Request) -> Response =
        fn(next: fn(Request) -> Response) -> fn(Request) -> Response {
            return fn(r: Request) -> Response {
                let resp: Response = next(r)
                let h: Header = Header { name: "X-Order", value: "first-" + resp.body }
                return Response { status: resp.status, headers: Cons(h, resp.headers), body: resp.body }
            }
        }

    let second_mw: fn(fn(Request) -> Response) -> fn(Request) -> Response =
        fn(next: fn(Request) -> Response) -> fn(Request) -> Response {
            return fn(r: Request) -> Response {
                let resp: Response = next(r)
                let h: Header = Header { name: "X-Inner", value: "second" }
                return Response { status: resp.status, headers: Cons(h, resp.headers), body: resp.body }
            }
        }

    let combined: fn(fn(Request) -> Response) -> fn(Request) -> Response = compose(first_mw, second_mw)
    let wrapped: fn(Request) -> Response = combined(handler)
    let req: Request = make_request("/")
    let resp: Response = wrapped(req)

    var has_first: bool
    match get_header(resp.headers, "X-Order") {
        Some(_) => { has_first = true }
        None => { has_first = false }
    }

    var has_second: bool
    match get_header(resp.headers, "X-Inner") {
        Some(_) => { has_second = true }
        None => { has_second = false }
    }

    assert(has_first and has_second)
}

test "middleware can short circuit" {
    let handler: fn(Request) -> Response = fn(req: Request) -> Response {
        return ok("should not reach")
    }

    let blocker: fn(fn(Request) -> Response) -> fn(Request) -> Response =
        fn(next: fn(Request) -> Response) -> fn(Request) -> Response {
            return fn(r: Request) -> Response {
                return ok("blocked")
            }
        }

    let wrapped: fn(Request) -> Response = apply_middleware(handler, blocker)
    let req: Request = make_request("/")
    let resp: Response = wrapped(req)
    assert(resp.body == "blocked")
}
