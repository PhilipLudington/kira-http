    assert(is_error)
    return
}

let test_parse_url_negative_port: fn() -> void = fn() -> void {
    let result: Result[Url, HttpError] = parse_url("https://example.com:-1/path")
    var is_error: bool
    match result {
        Ok(_) => { is_error = false }
        Err(_) => { is_error = true }
    }
    assert(is_error)
    return
}
