/// Tests for kira-http URL utilities
///
/// Tests URL parsing, URL building round-trips, query parameter extraction,
/// path parameter extraction, and invalid URL handling.

module http.tests.test_url

use http.types.HttpError
use http.types.QueryParam
use http.url.Url
use http.url.parse_url
use http.url.build_url
use http.url.parse_query_string
use http.url.get_query_param
use http.url.get_query_params
use http.url.extract_path_param
use http.url.path_matches

// URL parsing tests - various schemes

let test_parse_url_https: fn() -> void = fn() -> void {
    let result: Result[Url, HttpError] = parse_url("https://example.com/path")
    var is_valid: bool
    match result {
        Ok(url) => {
            is_valid = url.scheme == "https" and url.host == "example.com" and url.path == "/path"
        }
        Err(_) => { is_valid = false }
    }
    assert(is_valid)
    return
}

let test_parse_url_http: fn() -> void = fn() -> void {
    let result: Result[Url, HttpError] = parse_url("http://example.com")
    var is_valid: bool
    match result {
        Ok(url) => {
            is_valid = url.scheme == "http" and url.host == "example.com"
        }
        Err(_) => { is_valid = false }
    }
    assert(is_valid)
    return
}

let test_parse_url_ftp: fn() -> void = fn() -> void {
    let result: Result[Url, HttpError] = parse_url("ftp://files.example.com/download")
    var is_valid: bool
    match result {
        Ok(url) => {
            is_valid = url.scheme == "ftp" and url.host == "files.example.com"
        }
        Err(_) => { is_valid = false }
    }
    assert(is_valid)
    return
}

// URL parsing tests - with port

let test_parse_url_with_port: fn() -> void = fn() -> void {
    let result: Result[Url, HttpError] = parse_url("https://example.com:8080/api")
    var is_valid: bool
    match result {
        Ok(url) => {
            match url.port {
                Some(p) => { is_valid = p == 8080 }
                None => { is_valid = false }
            }
        }
        Err(_) => { is_valid = false }
    }
    assert(is_valid)
    return
}

