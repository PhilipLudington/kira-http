// ============================================================================
// Tests: with_header
// ============================================================================

test "with_header adds header" {
    let response: Response = with_header(ok("body"), "X-Custom", "value")

    var has_custom: bool
    match get_header(response.headers, "X-Custom") {
        Some(v) => { has_custom = v == "value" }
        None => { has_custom = false }
    }
    assert(has_custom)
}

test "with_header preserves existing headers" {
    let response: Response = with_header(ok("body"), "X-Custom", "value")

    var has_content_type: bool
    match get_header(response.headers, "Content-Type") {
        Some(v) => { has_content_type = v == "text/plain" }
        None => { has_content_type = false }
    }
    assert(has_content_type)
}

// ============================================================================
// Tests: with_body
// ============================================================================

test "with_body changes body" {
    let response: Response = with_body(ok("original"), "modified")
    assert(response.body == "modified")
}

test "with_body preserves status" {
    let response: Response = with_body(ok("original"), "modified")

    var matches: bool
    match response.status {
        OK => { matches = true }
        _ => { matches = false }
    }
    assert(matches)
}

// ============================================================================
// Tests: with_status
// ============================================================================

test "with_status changes status" {
    let response: Response = with_status(ok("body"), Created)

    var matches: bool
    match response.status {
        Created => { matches = true }
        _ => { matches = false }
    }
    assert(matches)
}

test "with_status preserves body" {
    let response: Response = with_status(ok("original body"), Created)
    assert(response.body == "original body")
}

// ============================================================================
// Tests: chaining
// ============================================================================

test "response chaining works" {
    let r1: Response = ok("initial")
    let r2: Response = with_header(r1, "X-Request-Id", "123")
    let r3: Response = with_body(r2, "final body")
    let response: Response = with_status(r3, Created)

    var is_created: bool
    match response.status {
        Created => { is_created = true }
        _ => { is_created = false }
    }

    var has_request_id: bool
    match get_header(response.headers, "X-Request-Id") {
        Some(v) => { has_request_id = v == "123" }
        None => { has_request_id = false }
    }

    assert(is_created and has_request_id and response.body == "final body")
}
