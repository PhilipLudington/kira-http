/// Tests for kira-http request builder
///
/// Tests RequestBuilder construction, header management, body handling,
/// and request building functionality.
/// Self-contained for Kira v0.1.0 (no module system support).

// ============================================================================
// Type Definitions
// ============================================================================

type Method =
    | GET
    | POST
    | PUT
    | DELETE
    | PATCH
    | HEAD
    | OPTIONS

type Header = {
    name: string,
    value: string
}

type Headers = List[Header]

type QueryParam = {
    key: string,
    value: string
}

type Request = {
    method: Method,
    url: string,
    path: string,
    headers: Headers,
    body: Option[string],
    query: List[QueryParam],
    path_params: List[QueryParam],
    timeout: Option[i32]
}

type RequestBuilder = {
    method: Method,
    url: string,
    headers: Headers,
    body: Option[string],
    timeout: Option[i32],
    max_redirects: Option[i32]
}

// ============================================================================
// Helper Functions
// ============================================================================

let set_header: fn(Headers, string, string) -> Headers =
    fn(headers: Headers, name: string, value: string) -> Headers {
        let without_existing: Headers = remove_header(headers, name)
        let new_header: Header = Header { name: name, value: value }
        return Cons(new_header, without_existing)
    }

let remove_header: fn(Headers, string) -> Headers =
    fn(headers: Headers, name: string) -> Headers {
        let lower_name: string = std.string.to_lower(name)
        return filter_headers(headers, lower_name)
    }

let filter_headers: fn(Headers, string) -> Headers =
    fn(headers: Headers, lower_name: string) -> Headers {
        var result: Headers
        match headers {
            Nil => { result = Nil }
            Cons(header, rest) => {
                let header_lower: string = std.string.to_lower(header.name)
                if header_lower == lower_name {
                    result = filter_headers(rest, lower_name)
                } else {
                    result = Cons(header, filter_headers(rest, lower_name))
                }
            }
        }
        return result
    }

let get_header: fn(Headers, string) -> Option[string] =
    fn(headers: Headers, name: string) -> Option[string] {
        let lower_name: string = std.string.to_lower(name)
        return find_header_value(headers, lower_name)
    }

let find_header_value: fn(Headers, string) -> Option[string] =
    fn(headers: Headers, lower_name: string) -> Option[string] {
        var result: Option[string]
        match headers {
            Nil => { result = None }
            Cons(header, rest) => {
                let header_lower: string = std.string.to_lower(header.name)
                if header_lower == lower_name {
                    result = Some(header.value)
                } else {
                    result = find_header_value(rest, lower_name)
                }
            }
        }
        return result
    }

let list_length: fn(List[string]) -> i32 = fn(list: List[string]) -> i32 {
    var count: i32
    match list {
        Nil => { count = 0 }
        Cons(_, rest) => { count = 1 + list_length(rest) }
    }
    return count
}

// ============================================================================
// RequestBuilder Functions
// ============================================================================

let new_request: fn(Method, string) -> RequestBuilder =
    fn(method: Method, url: string) -> RequestBuilder {
        return RequestBuilder {
            method: method,
            url: url,
            headers: Nil,
            body: None,
            timeout: None,
            max_redirects: None
        }
    }

let with_header: fn(RequestBuilder, string, string) -> RequestBuilder =
    fn(builder: RequestBuilder, name: string, value: string) -> RequestBuilder {
        return RequestBuilder {
            method: builder.method,
            url: builder.url,
            headers: set_header(builder.headers, name, value),
            body: builder.body,
            timeout: builder.timeout,
            max_redirects: builder.max_redirects
        }
    }

let with_headers: fn(RequestBuilder, Headers) -> RequestBuilder =
    fn(builder: RequestBuilder, headers: Headers) -> RequestBuilder {
        let merged: Headers = merge_headers(builder.headers, headers)
        return RequestBuilder {
            method: builder.method,
            url: builder.url,
            headers: merged,
            body: builder.body,
            timeout: builder.timeout,
            max_redirects: builder.max_redirects
        }
    }

let merge_headers: fn(Headers, Headers) -> Headers =
    fn(existing: Headers, new_headers: Headers) -> Headers {
        var result: Headers
        match new_headers {
            Nil => { result = existing }
            Cons(header, rest) => {
                let updated: Headers = set_header(existing, header.name, header.value)
                result = merge_headers(updated, rest)
            }
        }
        return result
    }

let with_body: fn(RequestBuilder, string) -> RequestBuilder =
    fn(builder: RequestBuilder, body: string) -> RequestBuilder {
        return RequestBuilder {
            method: builder.method,
            url: builder.url,
            headers: builder.headers,
            body: Some(body),
            timeout: builder.timeout,
            max_redirects: builder.max_redirects
        }
    }

let with_json: fn(RequestBuilder, string) -> RequestBuilder =
    fn(builder: RequestBuilder, json_data: string) -> RequestBuilder {
        let with_content_type: RequestBuilder = with_header(builder, "Content-Type", "application/json")
        return with_body(with_content_type, json_data)
    }

let with_timeout: fn(RequestBuilder, i32) -> RequestBuilder =
    fn(builder: RequestBuilder, ms: i32) -> RequestBuilder {
        return RequestBuilder {
            method: builder.method,
            url: builder.url,
            headers: builder.headers,
            body: builder.body,
            timeout: Some(ms),
            max_redirects: builder.max_redirects
        }
    }

let build: fn(RequestBuilder) -> Request =
    fn(builder: RequestBuilder) -> Request {
        let path_and_query: PathAndQuery = extract_path_and_query(builder.url)
        return Request {
            method: builder.method,
            url: builder.url,
            path: path_and_query.path,
            headers: builder.headers,
            body: builder.body,
            query: path_and_query.query,
            path_params: Nil,
            timeout: builder.timeout
        }
    }

type PathAndQuery = {
    path: string,
    query: List[QueryParam]
}

let unwrap_str: fn(Option[string]) -> string = fn(opt: Option[string]) -> string {
    var result: string
    match opt {
        Some(s) => { result = s }
        None => { result = "" }
    }
    return result
}

let extract_path_and_query: fn(string) -> PathAndQuery =
    fn(url: string) -> PathAndQuery {
        let scheme_end: Option[i64] = std.string.index_of(url, "://")
        var rest: string

        match scheme_end {
            Some(idx) => {
                rest = unwrap_str(std.string.substring(url, idx + 3, std.string.length(url)))
            }
            None => {
                rest = url
            }
        }

        // First, find the path start (/) and query start (?) positions
        let path_start: Option[i64] = std.string.index_of(rest, "/")
        let query_in_rest: Option[i64] = std.string.index_of(rest, "?")
        var path_portion: string

        match path_start {
            Some(idx) => {
                path_portion = unwrap_str(std.string.substring(rest, idx, std.string.length(rest)))
            }
            None => {
                // No path found - check if there's a query string directly on host
                match query_in_rest {
                    Some(q_idx) => {
                        // Query exists without path, include it with root path
                        path_portion = "/" + unwrap_str(std.string.substring(rest, q_idx, std.string.length(rest)))
                    }
                    None => {
                        path_portion = "/"
                    }
                }
            }
        }

        let query_start: Option[i64] = std.string.index_of(path_portion, "?")
        var path: string
        var query: List[QueryParam]

        match query_start {
            Some(idx) => {
                path = unwrap_str(std.string.substring(path_portion, 0, idx))
                let query_string: string = unwrap_str(std.string.substring(path_portion, idx + 1, std.string.length(path_portion)))
                query = parse_query_string(query_string)
            }
            None => {
                path = path_portion
                query = Nil
            }
        }

        return PathAndQuery {
            path: path,
            query: query
        }
    }

let parse_query_string: fn(string) -> List[QueryParam] =
    fn(query: string) -> List[QueryParam] {
        if std.string.length(query) == 0 {
            return Nil
        }
        return parse_query_pairs(query)
    }

let parse_query_pairs: fn(string) -> List[QueryParam] =
    fn(query: string) -> List[QueryParam] {
        let amp_idx: Option[i64] = std.string.index_of(query, "&")

        var current_pair: string
        var remaining: Option[string]

        match amp_idx {
            Some(idx) => {
                current_pair = unwrap_str(std.string.substring(query, 0, idx))
                remaining = Some(unwrap_str(std.string.substring(query, idx + 1, std.string.length(query))))
            }
            None => {
                current_pair = query
                remaining = None
            }
        }

        let eq_idx: Option[i64] = std.string.index_of(current_pair, "=")
        var param: QueryParam

        match eq_idx {
            Some(idx) => {
                param = QueryParam {
                    key: unwrap_str(std.string.substring(current_pair, 0, idx)),
                    value: unwrap_str(std.string.substring(current_pair, idx + 1, std.string.length(current_pair)))
                }
            }
            None => {
                param = QueryParam {
                    key: current_pair,
                    value: ""
                }
            }
        }

        match remaining {
            Some(rest) => {
                if std.string.length(rest) > 0 {
                    return Cons(param, parse_query_pairs(rest))
                } else {
                    return Cons(param, Nil)
                }
            }
            None => {
                return Cons(param, Nil)
            }
        }
    }

let get_query_param: fn(Request, string) -> Option[string] =
    fn(request: Request, name: string) -> Option[string] {
        return find_param(request.query, name)
    }

let get_query_params: fn(Request, string) -> List[string] =
    fn(request: Request, name: string) -> List[string] {
        return find_all_params(request.query, name)
    }

let path_param: fn(Request, string) -> Option[string] =
    fn(request: Request, name: string) -> Option[string] {
        return find_param(request.path_params, name)
    }

let find_param: fn(List[QueryParam], string) -> Option[string] =
    fn(params: List[QueryParam], name: string) -> Option[string] {
        var result: Option[string]
        match params {
            Nil => { result = None }
            Cons(param, rest) => {
                if param.key == name {
                    result = Some(param.value)
                } else {
                    result = find_param(rest, name)
                }
            }
        }
        return result
    }

let find_all_params: fn(List[QueryParam], string) -> List[string] =
    fn(params: List[QueryParam], name: string) -> List[string] {
        var result: List[string]
        match params {
            Nil => { result = Nil }
            Cons(param, rest) => {
                let rest_values: List[string] = find_all_params(rest, name)
                if param.key == name {
                    result = Cons(param.value, rest_values)
                } else {
                    result = rest_values
                }
            }
        }
        return result
    }

let with_path_params: fn(Request, List[QueryParam]) -> Request =
    fn(request: Request, params: List[QueryParam]) -> Request {
        return Request {
            method: request.method,
            url: request.url,
            path: request.path,
            headers: request.headers,
            body: request.body,
            query: request.query,
            path_params: params,
            timeout: request.timeout
        }
    }

// ============================================================================
// Tests: new_request
// ============================================================================

test "new_request sets method to GET" {
    let builder: RequestBuilder = new_request(GET, "https://example.com")
    var matches: bool
    match builder.method {
        GET => { matches = true }
        _ => { matches = false }
    }
    assert(matches)
}

test "new_request sets url" {
    let builder: RequestBuilder = new_request(GET, "https://example.com")
    assert(builder.url == "https://example.com")
}

test "new_request has empty headers" {
    let builder: RequestBuilder = new_request(GET, "https://example.com")
    var is_empty: bool
    match builder.headers {
        Nil => { is_empty = true }
        Cons(_, _) => { is_empty = false }
    }
    assert(is_empty)
}

test "new_request has no body" {
    let builder: RequestBuilder = new_request(GET, "https://example.com")
    var is_none: bool
    match builder.body {
        None => { is_none = true }
        Some(_) => { is_none = false }
    }
    assert(is_none)
}

test "new_request has no timeout" {
    let builder: RequestBuilder = new_request(GET, "https://example.com")
    var is_none: bool
    match builder.timeout {
        None => { is_none = true }
        Some(_) => { is_none = false }
    }
    assert(is_none)
}

test "new_request sets method to POST" {
    let builder: RequestBuilder = new_request(POST, "https://example.com/api")
    var matches: bool
    match builder.method {
        POST => { matches = true }
        _ => { matches = false }
    }
    assert(matches)
}

// ============================================================================
// Tests: with_header
// ============================================================================

test "with_header adds header" {
    let b1: RequestBuilder = new_request(GET, "https://example.com")
    let builder: RequestBuilder = with_header(b1, "Content-Type", "application/json")
    var found: bool
    match get_header(builder.headers, "Content-Type") {
        Some(v) => { found = v == "application/json" }
        None => { found = false }
    }
    assert(found)
}

test "with_header chains multiple headers" {
    let b1: RequestBuilder = new_request(GET, "https://example.com")
    let b2: RequestBuilder = with_header(b1, "Content-Type", "application/json")
    let builder: RequestBuilder = with_header(b2, "Accept", "text/html")

    var has_content_type: bool
    match get_header(builder.headers, "Content-Type") {
        Some(v) => { has_content_type = v == "application/json" }
        None => { has_content_type = false }
    }

    var has_accept: bool
    match get_header(builder.headers, "Accept") {
        Some(v) => { has_accept = v == "text/html" }
        None => { has_accept = false }
    }

    assert(has_content_type and has_accept)
}

test "with_header replaces existing header" {
    let b1: RequestBuilder = new_request(GET, "https://example.com")
    let b2: RequestBuilder = with_header(b1, "Content-Type", "text/plain")
    let builder: RequestBuilder = with_header(b2, "Content-Type", "application/json")

    var found: bool
    match get_header(builder.headers, "Content-Type") {
        Some(v) => { found = v == "application/json" }
        None => { found = false }
    }
    assert(found)
}

// ============================================================================
// Tests: with_headers
// ============================================================================

test "with_headers adds multiple headers" {
    let headers: Headers = Cons(
        Header { name: "Content-Type", value: "application/json" },
        Cons(
            Header { name: "Accept", value: "text/html" },
            Nil
        )
    )
    let b1: RequestBuilder = new_request(GET, "https://example.com")
    let builder: RequestBuilder = with_headers(b1, headers)

    var has_content_type: bool
    match get_header(builder.headers, "Content-Type") {
        Some(v) => { has_content_type = v == "application/json" }
        None => { has_content_type = false }
    }

    var has_accept: bool
    match get_header(builder.headers, "Accept") {
        Some(v) => { has_accept = v == "text/html" }
        None => { has_accept = false }
    }

    assert(has_content_type and has_accept)
}

test "with_headers preserves existing headers with empty list" {
    let b1: RequestBuilder = new_request(GET, "https://example.com")
    let b2: RequestBuilder = with_header(b1, "Existing", "value")
    let builder: RequestBuilder = with_headers(b2, Nil)

    var found: bool
    match get_header(builder.headers, "Existing") {
        Some(v) => { found = v == "value" }
        None => { found = false }
    }
    assert(found)
}

// ============================================================================
// Tests: with_body
// ============================================================================

test "with_body sets body" {
    let b1: RequestBuilder = new_request(POST, "https://example.com")
    let builder: RequestBuilder = with_body(b1, "request body")

    var has_body: bool
    match builder.body {
        Some(b) => { has_body = b == "request body" }
        None => { has_body = false }
    }
    assert(has_body)
}

test "with_body replaces existing body" {
    let b1: RequestBuilder = new_request(POST, "https://example.com")
    let b2: RequestBuilder = with_body(b1, "first body")
    let builder: RequestBuilder = with_body(b2, "second body")

    var has_body: bool
    match builder.body {
        Some(b) => { has_body = b == "second body" }
        None => { has_body = false }
    }
    assert(has_body)
}

// ============================================================================
// Tests: with_json
// ============================================================================

test "with_json sets body" {
    let b1: RequestBuilder = new_request(POST, "https://example.com")
    let builder: RequestBuilder = with_json(b1, "{\"name\": \"Alice\"}")

    var has_body: bool
    match builder.body {
        Some(b) => { has_body = b == "{\"name\": \"Alice\"}" }
        None => { has_body = false }
    }
    assert(has_body)
}

test "with_json sets content type" {
    let b1: RequestBuilder = new_request(POST, "https://example.com")
    let builder: RequestBuilder = with_json(b1, "{\"name\": \"Alice\"}")

    var has_content_type: bool
    match get_header(builder.headers, "Content-Type") {
        Some(v) => { has_content_type = v == "application/json" }
        None => { has_content_type = false }
    }
    assert(has_content_type)
}

// ============================================================================
// Tests: with_timeout
// ============================================================================

test "with_timeout sets timeout" {
    let b1: RequestBuilder = new_request(GET, "https://example.com")
    let builder: RequestBuilder = with_timeout(b1, 5000)

    var has_timeout: bool
    match builder.timeout {
        Some(t) => { has_timeout = t == 5000 }
        None => { has_timeout = false }
    }
    assert(has_timeout)
}

test "with_timeout replaces existing timeout" {
    let b1: RequestBuilder = new_request(GET, "https://example.com")
    let b2: RequestBuilder = with_timeout(b1, 5000)
    let builder: RequestBuilder = with_timeout(b2, 10000)

    var has_timeout: bool
    match builder.timeout {
        Some(t) => { has_timeout = t == 10000 }
        None => { has_timeout = false }
    }
    assert(has_timeout)
}

// ============================================================================
// Tests: build
// ============================================================================

test "build sets method" {
    let b1: RequestBuilder = new_request(GET, "https://example.com")
    let request: Request = build(b1)

    var matches: bool
    match request.method {
        GET => { matches = true }
        _ => { matches = false }
    }
    assert(matches)
}

test "build sets url" {
    let b1: RequestBuilder = new_request(GET, "https://example.com/path")
    let request: Request = build(b1)

    assert(request.url == "https://example.com/path")
}

test "build extracts path" {
    let b1: RequestBuilder = new_request(GET, "https://example.com/users/123")
    let request: Request = build(b1)

    assert(request.path == "/users/123")
}

test "build extracts path with query" {
    let b1: RequestBuilder = new_request(GET, "https://example.com/search?q=test")
    let request: Request = build(b1)

    assert(request.path == "/search")
}

test "build extracts query params" {
    let b1: RequestBuilder = new_request(GET, "https://example.com/search?q=test&limit=10")
    let request: Request = build(b1)

    var has_q: bool
    match get_query_param(request, "q") {
        Some(v) => { has_q = v == "test" }
        None => { has_q = false }
    }

    var has_limit: bool
    match get_query_param(request, "limit") {
        Some(v) => { has_limit = v == "10" }
        None => { has_limit = false }
    }

    assert(has_q and has_limit)
}

test "build preserves headers" {
    let b1: RequestBuilder = new_request(GET, "https://example.com")
    let b2: RequestBuilder = with_header(b1, "Authorization", "Bearer token")
    let request: Request = build(b2)

    var has_auth: bool
    match get_header(request.headers, "Authorization") {
        Some(v) => { has_auth = v == "Bearer token" }
        None => { has_auth = false }
    }
    assert(has_auth)
}

test "build preserves body" {
    let b1: RequestBuilder = new_request(POST, "https://example.com")
    let b2: RequestBuilder = with_body(b1, "body content")
    let request: Request = build(b2)

    var has_body: bool
    match request.body {
        Some(b) => { has_body = b == "body content" }
        None => { has_body = false }
    }
    assert(has_body)
}

test "build defaults path to /" {
    let b1: RequestBuilder = new_request(GET, "https://example.com")
    let request: Request = build(b1)

    assert(request.path == "/")
}

test "build preserves timeout" {
    let b1: RequestBuilder = new_request(GET, "https://example.com")
    let b2: RequestBuilder = with_timeout(b1, 3000)
    let request: Request = build(b2)

    var has_timeout: bool
    match request.timeout {
        Some(t) => { has_timeout = t == 3000 }
        None => { has_timeout = false }
    }
    assert(has_timeout)
}

test "build has no timeout by default" {
    let b1: RequestBuilder = new_request(GET, "https://example.com")
    let request: Request = build(b1)

    var has_no_timeout: bool
    match request.timeout {
        None => { has_no_timeout = true }
        Some(_) => { has_no_timeout = false }
    }
    assert(has_no_timeout)
}

// ============================================================================
// Tests: get_query_param
// ============================================================================

test "get_query_param finds existing param" {
    let b1: RequestBuilder = new_request(GET, "https://example.com?name=Alice")
    let request: Request = build(b1)

    var found: bool
    match get_query_param(request, "name") {
        Some(v) => { found = v == "Alice" }
        None => { found = false }
    }
    assert(found)
}

test "get_query_param returns None for missing param" {
    let b1: RequestBuilder = new_request(GET, "https://example.com?name=Alice")
    let request: Request = build(b1)

    var not_found: bool
    match get_query_param(request, "age") {
        Some(_) => { not_found = false }
        None => { not_found = true }
    }
    assert(not_found)
}

// ============================================================================
// Tests: get_query_params
// ============================================================================

test "get_query_params finds multiple values" {
    let b1: RequestBuilder = new_request(GET, "https://example.com?tag=a&tag=b&tag=c")
    let request: Request = build(b1)

    let tags: List[string] = get_query_params(request, "tag")
    let count: i32 = list_length(tags)
    assert(count == 3)
}

test "get_query_params returns empty for missing param" {
    let b1: RequestBuilder = new_request(GET, "https://example.com")
    let request: Request = build(b1)

    let tags: List[string] = get_query_params(request, "tag")
    var is_empty: bool
    match tags {
        Nil => { is_empty = true }
        Cons(_, _) => { is_empty = false }
    }
    assert(is_empty)
}

// ============================================================================
// Tests: path_param
// ============================================================================

test "path_param finds existing param" {
    let b1: RequestBuilder = new_request(GET, "https://example.com/users/123")
    let request: Request = build(b1)
    let params: List[QueryParam] = Cons(
        QueryParam { key: "id", value: "123" },
        Nil
    )
    let req_with_params: Request = with_path_params(request, params)

    var found: bool
    match path_param(req_with_params, "id") {
        Some(v) => { found = v == "123" }
        None => { found = false }
    }
    assert(found)
}

test "path_param returns None for missing param" {
    let b1: RequestBuilder = new_request(GET, "https://example.com/users/123")
    let request: Request = build(b1)

    var not_found: bool
    match path_param(request, "id") {
        Some(_) => { not_found = false }
        None => { not_found = true }
    }
    assert(not_found)
}

// ============================================================================
// Tests: full builder chain
// ============================================================================

test "full builder chain works" {
    let b1: RequestBuilder = new_request(POST, "https://api.example.com/users?notify=true")
    let b2: RequestBuilder = with_header(b1, "Authorization", "Bearer token123")
    let b3: RequestBuilder = with_header(b2, "Accept", "application/json")
    let b4: RequestBuilder = with_json(b3, "{\"name\": \"Alice\"}")
    let b5: RequestBuilder = with_timeout(b4, 5000)
    let request: Request = build(b5)

    var is_post: bool
    match request.method {
        POST => { is_post = true }
        _ => { is_post = false }
    }

    var has_auth: bool
    match get_header(request.headers, "Authorization") {
        Some(v) => { has_auth = v == "Bearer token123" }
        None => { has_auth = false }
    }

    var has_body: bool
    match request.body {
        Some(b) => { has_body = b == "{\"name\": \"Alice\"}" }
        None => { has_body = false }
    }

    var has_notify: bool
    match get_query_param(request, "notify") {
        Some(v) => { has_notify = v == "true" }
        None => { has_notify = false }
    }

    assert(is_post and has_auth and has_body and has_notify)
}
